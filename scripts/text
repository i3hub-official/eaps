          {#if connectionStatus === 'connected'}
            <Wifi size={14}/>
          {:else if connectionStatus === 'connecting'}
            <WifiOff size={14} class="pulse"/>
          {:else if connectionStatus === 'error'}
            <AlertTriangle size={14}/>
          {:else}
            <WifiOff size={14}/>
          {/if}
          <span>{connectionStatus}</span>
        </div>
        {#if seedMetrics.estimatedTimeRemaining > 0}
          <div class="eta-display">
            <Clock size={14}/>
            <span>ETA: {formatDuration(seedMetrics.estimatedTimeRemaining)}</span>
          </div>
        {/if}
        {#if seedMetrics.recordsPerSecond > 0}
          <div class="rps-display">
            <Zap size={14}/>
            <span>{seedMetrics.recordsPerSecond} steps/sec</span>
          </div>
        {/if}
      </div>
    {/if}

    <!-- ═══════════════════════════════════════════════════════════════
         OVERVIEW VIEW
         ═══════════════════════════════════════════════════════════════ -->
    {#if activeView === 'overview'}
      
      <!-- Current Counts Grid -->
      <section class="counts-section">
        <div class="section-header">
          <h2 class="section-title">
            <Activity size={16}/>
            Current Database State
          </h2>
          <button class="refresh-btn-sm" onclick={() => window.location.reload()} title="Refresh (Ctrl+R)">
            <RefreshCw size={14}/>
          </button>
        </div>
        <div class="counts-grid">
          {#each Object.entries(data.counts) as [key, val]}
            <button class="count-card" class:populated={val > 0} onclick={() => loadPreview(key)} class:selected={selectedEntity === key}>
              <div class="count-indicator" class:active={val > 0}></div>
              <div class="count-info">
                <span class="count-number">{val}</span>
                <span class="count-name">{key}</span>
              </div>
              {#if val > 0}
                <CheckCircle2 size={14} class="count-check"/>
              {:else}
                <MinusCircle size={14} class="count-empty"/>
              {/if}
            </button>
          {/each}
        </div>
      </section>

      <!-- Data Preview Panel -->
      {#if selectedEntity && !seeding}
        <section class="preview-panel" transition:slide>
          <div class="preview-header">
            <h3>{selectedEntity} Preview</h3>
            <button class="close-btn" onclick={() => selectedEntity = null}>
              <X size={16}/>
            </button>
          </div>
          {#if previewLoading}
            <div class="preview-loading">
              <Loader2 size={24} class="spin"/>
              <span>Loading preview...</span>
            </div>
          {:else if previewData[selectedEntity]}
            <div class="preview-table-wrap">
              <table class="preview-table">
                <thead>
                  <tr>
                    {#each Object.keys(previewData[selectedEntity][0] || {}) as col}
                      <th>{col}</th>
                    {/each}
                  </tr>
                </thead>
                <tbody>
                  {#each previewData[selectedEntity] as row}
                    <tr>
                      {#each Object.values(row) as cell}
                        <td>{cell}</td>
                      {/each}
                    </tr>
                  {/each}
                </tbody>
              </table>
            </div>
          {/if}
        </section>
      {/if}

      <!-- Progress Section -->
      {#if seeding}
        <section class="progress-card" transition:slide={{ duration: 300, easing: cubicOut }}>
          <div class="progress-header">
            <div class="progress-title">
              <div class="progress-pulse"></div>
              <span>Seeding in Progress</span>
            </div>
            <span class="progress-percentage">{Math.round((progress.current / progress.total) * 100)}%</span>
          </div>

          <div class="progress-track">
            <div class="progress-fill" style="width: {Math.min((progress.current / progress.total) * 100, 100)}%"></div>
          </div>

          <div class="progress-meta">
            <span class="progress-step-name">
              {#if progress.step}
                <Loader2 size={14} class="spin"/>
                {progress.step}
              {:else}
                Initializing...
              {/if}
            </span>
            {#if progress.detail}
              <span class="progress-detail">{progress.detail}</span>
            {/if}
            <span class="progress-fraction">{progress.current} of {progress.total} steps</span>
          </div>

          <!-- Categorized Step Timeline -->
          <div class="timeline-categories">
            {#each categories as cat (cat.key)}
              {@const catSteps = seedSteps.filter((_, i) => seedSteps[i].category === cat.key)}
              {@const catCompleted = catSteps.filter((_, i) => getStepStatus(seedSteps.findIndex(s => s.key === catSteps[i].key), progress.current) === 'completed').length}
              {@const catActive = catSteps.some((_, i) => getStepStatus(seedSteps.findIndex(s => s.key === catSteps[i].key), progress.current) === 'active')}
              <div class="cat-block" class:active={catActive} class:done={catCompleted === catSteps.length}>
                <div class="cat-header">
                  <svelte:component this={cat.icon} size={14} style="color: {cat.color}"/>
                  <span>{cat.label}</span>
                  <span class="cat-count">{catCompleted}/{catSteps.length}</span>
                </div>
                <div class="cat-progress-track">
                  <div class="cat-progress-fill" style="width: {(catCompleted / catSteps.length) * 100}%; background: {cat.color}"></div>
                </div>
              </div>
            {/each}
          </div>

          <!-- Detailed Timeline -->
          <div class="step-timeline">
            {#each seedSteps as step, i (step.key)}
              {@const status = getStepStatus(i, progress.current)}
              <div class="timeline-item {status}" class:expanded={expandedSteps.has(i)}>
                <div class="timeline-connector" class:hidden={i === 0}></div>
                <button class="timeline-node" style="--step-color: {step.color}" onclick={() => toggleStep(i)}>
                  {#if status === 'completed'}
                    <CheckCircle2 size={14}/>
                  {:else if status === 'active'}
                    <Loader2 size={14} class="spin"/>
                  {:else}
                    <svelte:component this={step.icon} size={14}/>
                  {/if}
                </button>
                <div class="timeline-content">
                  <span class="timeline-label">{step.label}</span>
                  <span class="timeline-desc">{step.description}</span>
                  {#if step.total !== null}
                    <span class="timeline-count">~{step.total}</span>
                  {/if}
                </div>
                <ChevronRight size={14} class={`timeline-chevron ${expandedSteps.has(i) ? 'rotated' : ''}`}/>
              </div>
              {#if expandedSteps.has(i)}
                <div class="timeline-detail" transition:slide>
                  <p>{step.description}</p>
                  <div class="detail-meta">
                    <span class="meta-tag" style="background: {step.color}20; color: {step.color}">
                      {step.category}
                    </span>
                    <span class="meta-tag">
                      {step.total !== null ? `~${step.total} records` : 'Dynamic count'}
                    </span>
                  </div>
                </div>
              {/if}
            {/each}
          </div>

          <!-- Live Logs -->
          <div class="logs-section">
            <div class="logs-header">
              <button class="logs-toggle" onclick={() => showLogs = !showLogs}>
                <Terminal size={14}/>
                <span>Live Terminal</span>
                <span class="logs-badge">{filteredLogs.length}</span>
                <ChevronRight size={14} class={`logs-chevron ${showLogs ? 'rotated' : ''}`}/>
              </button>
              <div class="logs-actions">
                <div class="log-filters">
                  {#each ['all', 'info', 'success', 'error'] as f}
                    <button class="filter-pill" class:active={logFilter === f} onclick={() => logFilter = f}>
                      {f}
                    </button>
                  {/each}
                </div>
                <button class="icon-btn" onclick={copyLogs} title="Copy logs">
                  <Copy size={14}/>
                </button>
                <button class="icon-btn" onclick={exportReport} title="Export report">
                  <Download size={14}/>
                </button>
              </div>
            </div>
            
            {#if showLogs}
              <div class="logs-panel" transition:slide={{ duration: 200 }}>
                {#if filteredLogs.length === 0}
                  <div class="log-empty">Waiting for server response...</div>
                {:else}
                  {#each filteredLogs as log, i}
                    <div class="log-entry log-{log.type}" in:fade={{ delay: i * 20 }}>
                      <span class="log-time">[{log.time}]</span>
                      <span class="log-msg">{log.msg}</span>
                    </div>
                  {/each}
                {/if}
              </div>
            {/if}
          </div>
        </section>
      {/if}

      <!-- Results -->
      {#if form?.success && form.results && !seeding}
        <section class="result-card success" transition:fly={{ y: 20, duration: 300 }}>
          <div class="result-icon-wrap">
            <Sparkles size={24}/>
          </div>
          <div class="result-content">
            <h3>Seed Complete!</h3>
            <div class="result-metrics">
              <div class="metric">
                <Clock size={16}/>
                <span>{seedMetrics.endTime && seedMetrics.startTime ? formatDuration(seedMetrics.endTime - seedMetrics.startTime) : 'N/A'}</span>
              </div>
              <div class="metric">
                <Database size={16}/>
                <span>{form.results.length} steps completed</span>
              </div>
            </div>
            <div class="result-lines">
              {#each form.results as line}
                <p>{line}</p>
              {/each}
            </div>
            <div class="result-actions">
              <button class="refresh-btn" onclick={() => window.location.reload()}>
                <RotateCcw size={14}/>
                Refresh to see updated data
              </button>
              <button class="export-btn" onclick={exportReport}>
                <FileJson size={14}/>
                Export Report
              </button>
            </div>
          </div>
        </section>
      {:else if form?.error && !seeding}
        <section class="result-card error" transition:fly={{ y: 20, duration: 300 }}>
          <div class="result-icon-wrap error">
            <ShieldAlert size={24}/>
          </div>
          <div class="result-content">
            <h3>Seed Failed</h3>
            <p class="error-message">{form.error}</p>
            <button class="retry-btn" onclick={() => document.querySelector<HTMLButtonElement>('.seed-btn')?.click()}>
              <RefreshCw size={14}/>
              Retry
            </button>
          </div>
        </section>
      {/if}

      <!-- Actions -->
      <section class="actions-section">
        <div class="actions-grid">
          <form method="POST" action="?/seed" use:enhance={() => {
            resetProgress();
            seeding = true;
            addLog('Starting seed process...');
            startSSE();
            return async ({ update }) => update();
          }}>
            <button class="action-btn seed-btn" disabled={seeding || resetting}>
              {#if seeding}
                <Loader2 size={18} class="spin"/>
                <span>Seeding Database...</span>
                <span class="btn-meta">{progress.current}/{progress.total}</span>
              {:else}
                <Sprout size={18}/>
                <span>Seed Database</span>
                <ArrowRight size={16} class="btn-arrow"/>
              {/if}
            </button>
          </form>

          <form method="POST" action="?/reset" use:enhance={() => {
            if (!confirm('DANGER: This will permanently delete all data including users, exams, results, and audit logs. This action cannot be undone. Continue?')) return () => {};
            resetting = true;
            addLog('Resetting database...');
            return async ({ update }) => {
              const result = await update();
              resetting = false;
              setTimeout(() => window.location.reload(), 1500);
              return result;
            };
          }}>
            <button class="action-btn reset-btn" disabled={seeding || resetting}>
              {#if resetting}
                <Loader2 size={18} class="spin"/>
                <span>Resetting...</span>
              {:else}
                <Trash2 size={18}/>
                <span>Reset All Data</span>
              {/if}
            </button>
          </form>
        </div>
        <p class="actions-hint">
          <Keyboard size={12}/>
          <span>Shortcuts: <kbd>Ctrl+S</kbd> Seed · <kbd>Ctrl+L</kbd> Logs · <kbd>Ctrl+R</kbd> Refresh</span>
        </p>
      </section>
    {/if}

    <!-- ═══════════════════════════════════════════════════════════════
         DETAILS VIEW
         ═══════════════════════════════════════════════════════════════ -->
    {#if activeView === 'details' && !seeding && !form}
      <div class="info-grid">
        <!-- Academic Calendar -->
        <section class="info-card">
          <div class="info-header">
            <CalendarDays size={16}/>
            <h3>Academic Calendar 2025/2026</h3>
          </div>
          <div class="semesters-grid">
            {#each semesterDefs as sem}
              <div class="semester-card" style="--sem-color: {sem.color}">
                <div class="semester-icon">
                  <svelte:component this={sem.icon} size={20}/>
                </div>
                <div class="semester-info">
                  <span class="semester-name">{sem.name}</span>
                  <span class="semester-months">{sem.months}</span>
                  <div class="semester-meta">
                    <span><Clock size={12}/> {sem.weeks} weeks</span>
                    <span><Sun size={12}/> {sem.holidays} breaks</span>
                  </div>
                </div>
                <span class="semester-badge">{sem.short}</span>
              </div>
            {/each}
          </div>
        </section>

        <!-- Credit Caps -->
        <section class="info-card wide">
          <div class="info-header">
            <CreditCard size={16}/>
            <h3>Credit Caps per Level</h3>
            <button class="info-action" onclick={() => {}} title="View full policy">
              <FileText size={14}/>
            </button>
          </div>
          <div class="caps-visualization">
            {#each creditCapRows as row}
              <div class="cap-bar-item">
                <div class="cap-bar-header">
                  <span class="cap-level">{row.level}</span>
                  <span class="cap-total">{row.sem1 + row.sem2} CU/yr</span>
                </div>
                <div class="cap-bar-track">
                  <div class="cap-bar-fill" style="width: {((row.sem1 + row.sem2) / 48) * 100}%; background: linear-gradient(90deg, #3b82f6, #8b5cf6)"></div>
                </div>
                <div class="cap-bar-details">
                  <span>Sem 1: <strong>{row.sem1}</strong></span>
                  <span>Sem 2: <strong>{row.sem2}</strong></span>
                  <span>Carry: <strong class:zero={row.carryOver === 0}>{row.carryOver === 0 ? '—' : row.carryOver}</strong></span>
                  <span>Borrow: <strong>{row.borrowed}</strong></span>
                </div>
              </div>
            {/each}
          </div>
          <p class="info-note">
            <Info size={12}/>
            100L has no carry-over credits as there is no previous level. Maximum borrow limit is 6 CU across all levels.
          </p>
        </section>

        <!-- Entity Relationships -->
        <section class="info-card wide">
          <div class="info-header">
            <GitBranch size={16}/>
            <h3>Data Model Relationships</h3>
          </div>
          <div class="relations-graph">
            {#each entityRelations as rel}
              <div class="relation-row">
                <span class="rel-entity" style="background: {seedSteps.find(s => s.key === rel.from)?.color || '#64748b'}20; color: {seedSteps.find(s => s.key === rel.from)?.color || '#64748b'}">
                  {rel.from}
                </span>
                <div class="rel-line">
                  <span class="rel-type">{rel.type}</span>
                  <div class="rel-connector"></div>
                </div>
                <span class="rel-entity" style="background: {seedSteps.find(s => s.key === rel.to)?.color || '#64748b'}20; color: {seedSteps.find(s => s.key === rel.to)?.color || '#64748b'}">
                  {rel.to}
                </span>
                <span class="rel-label">{rel.label}</span>
              </div>
            {/each}
          </div>
        </section>

        <!-- What Gets Seeded -->
        <section class="info-card wide">
          <div class="info-header">
            <Layers size={16}/>
            <h3>Seed Overview</h3>
            <span class="seed-total">~{getTotalRecords()} records</span>
          </div>
          <div class="seed-category-groups">
            {#each categories as cat}
              {@const catSteps = seedSteps.filter(s => s.category === cat.key)}
              <div class="seed-cat-group">
                <div class="seed-cat-header" style="color: {cat.color}">
                  <svelte:component this={cat.icon} size={16}/>
                  <span>{cat.label}</span>
                  <span class="seed-cat-count">{catSteps.reduce((a, s) => a + (s.total || 0), 0)}</span>
                </div>
                <div class="seed-list">
                  {#each catSteps as step, i}
                    <div class="seed-item" style="--item-color: {step.color}">
                      <div class="seed-number">{seedSteps.indexOf(step) + 1}</div>
                      <div class="seed-icon">
                        <svelte:component this={step.icon} size={16}/>
                      </div>
                      <span class="seed-label">{step.label}</span>
                      {#if step.total !== null}
                        <span class="seed-count">~{step.total}</span>
                      {:else}
                        <span class="seed-count auto">auto</span>
                      {/if}
                    </div>
                  {/each}
                </div>
              </div>
            {/each}
          </div>
        </section>
      </div>
    {/if}

    <!-- ═══════════════════════════════════════════════════════════════
         ANALYTICS VIEW
         ═══════════════════════════════════════════════════════════════ -->
    {#if activeView === 'analytics' && !seeding && !form}
      <div class="analytics-grid">
        <!-- Seed History -->
        <section class="analytics-card">
          <div class="analytics-header">
            <History size={16}/>
            <h3>Seed History</h3>
          </div>
          <div class="history-list">
            {#each seedHistory as h}
              <div class="history-item">
                <div class="history-status" class:success={h.status === 'success'}>
                  {#if h.status === 'success'}
                    <CheckCircle2 size={16}/>
                  {:else}
                    <XCircle size={16}/>
                  {/if}
                </div>
                <div class="history-info">
                  <span class="history-date">{new Date(h.date).toLocaleDateString()}</span>
                  <span class="history-meta">{h.records} records · {formatDuration(h.duration)}</span>
                </div>
                <span class="history-user">{h.triggeredBy}</span>
              </div>
            {/each}
          </div>
        </section>

        <!-- Data Distribution -->
        <section class="analytics-card wide">
          <div class="analytics-header">
            <PieChart size={16}/>
            <h3>Current Data Distribution</h3>
          </div>
          <div class="distribution-bars">
            {#each Object.entries(data.counts) as [key, val], i}
              {@const max = Math.max(...Object.values(data.counts))}
              {@const colors = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4']}
              <div class="dist-item">
                <span class="dist-label">{key}</span>
                <div class="dist-track">
                  <div class="dist-fill" style="width: {(val / max) * 100}%; background: {colors[i % colors.length]}"></div>
                </div>
                <span class="dist-value">{val}</span>
              </div>
            {/each}
          </div>
        </section>

        <!-- Performance Tips -->
        <section class="analytics-card">
          <div class="analytics-header">
            <Zap size={16}/>
            <h3>Optimization Tips</h3>
          </div>
          <div class="tips-list">
            <div class="tip-item">
              <CheckSquare size={16} style="color: #10b981"/>
              <span>Use <code>createMany()</code> for bulk inserts — 85% faster than individual creates</span>
            </div>
            <div class="tip-item">
              <CheckSquare size={16} style="color: #10b981"/>
              <span>Transactions wrap related operations for atomicity</span>
            </div>
            <div class="tip-item">
              <CheckSquare size={16} style="color: #10b981"/>
              <span><code>skipDuplicates</code> prevents constraint violations on re-runs</span>
            </div>
            <div class="tip-item">
              <AlertTriangle size={16} style="color: #f59e0b"/>
              <span>Reset requires admin privileges — verify role before destructive operations</span>
            </div>
          </div>
        </section>
      </div>
    {/if}

    <!-- ═══════════════════════════════════════════════════════════════
         WARNING BANNER
         ═══════════════════════════════════════════════════════════════ -->
    <div class="warning-banner">
      <ShieldAlert size={18}/>
      <div class="warning-content">
        <strong>Production Notice</strong>
        <span>Remove or protect this route before deploying to production. Database seeding exposes sensitive administrative functions.</span>
      </div>
    </div>

  </div>
</div>

