  } from '@lucide/svelte';

  let { data }: { data: PageData } = $props();
  let form = $state<ActionData | null>(null);
  let seeding = $state(false);
  let resetting = $state(false);

  let progress = $state({ current: 0, total: 0, step: '', detail: '' });
  let logs = $state<string[]>([]);
  let showLogs = $state(false);
  let logFilter = $state<'all' | 'info' | 'error' | 'success'>('all');

  let eventSource: EventSource | null = null;
  let seedResults = $state<string[]>([]);
  let expandedSteps = $state<Set<number>>(new Set());

  // ── NEW: View state management ──
  let activeView = $state<'overview' | 'details' | 'analytics'>('overview');
  let showPreview = $state(false);
  let selectedEntity = $state<string | null>(null);

  // ── NEW: Connection health ──
  let connectionStatus = $state<'connected' | 'connecting' | 'disconnected' | 'error'>('disconnected');
  let connectionLatency = $state(0);
  let lastHeartbeat = $state<Date | null>(null);

  // ── NEW: Performance metrics ──
  let seedMetrics = $state({
    startTime: null as number | null,
    endTime: null as number | null,
    recordsPerSecond: 0,
    peakMemory: 0,
    currentMemory: 0,
    estimatedTimeRemaining: 0
  });

  // ── NEW: Data preview state ──
  let previewData = $state<Record<string, any[]>>({});
  let previewLoading = $state(false);

  // ── Step definitions with enhanced metadata ──
  const seedSteps = [
    { key: 'levels',        label: 'Academic Levels', icon: GraduationCap, total: 8,    emoji: '📊', color: '#8b5cf6', category: 'academic', description: '100L through 800L academic progression levels' },
    { key: 'semesters',     label: 'Semesters',       icon: CalendarDays,  total: 2,    emoji: '📅', color: '#06b6d4', category: 'academic', description: 'First and Second semester definitions for 2025/2026' },
    { key: 'configs',       label: 'Credit Caps',     icon: CreditCard,    total: 16,   emoji: '🎯', color: '#ec4899', category: 'academic', description: 'Level/semester credit unit limits and carry-over rules' },
    { key: 'colleges',      label: 'Colleges',        icon: Building2,     total: 12,   emoji: '🏛️', color: '#f59e0b', category: 'institution', description: 'All 12 MOUAU colleges and schools' },
    { key: 'departments',   label: 'Departments',     icon: Building2,     total: 57,   emoji: '🏢', color: '#f97316', category: 'institution', description: '57 academic departments across all colleges' },
    { key: 'staff',         label: 'Staff Users',     icon: Users,         total: 62,   emoji: '👥', color: '#6366f1', category: 'users', description: 'Admins, lecturers, and invigilators' },
    { key: 'students',      label: 'Students',        icon: Users,         total: 45,   emoji: '🎓', color: '#3b82f6', category: 'users', description: 'Student accounts across multiple departments and levels' },
    { key: 'courses',       label: 'Courses',         icon: BookOpen,      total: 400,  emoji: '📚', color: '#10b981', category: 'academic', description: 'Course catalog with credit units and semester assignments' },
    { key: 'registrations', label: 'Registrations',   icon: FileCheck,     total: null, emoji: '📋', color: '#14b8a6', category: 'academic', description: 'Auto-generated course registrations per student' },
    { key: 'exam',          label: 'Exams',           icon: ShieldCheck,   total: 2,    emoji: '📝', color: '#ef4444', category: 'examination', description: 'Sample exam configurations with invigilator assignments' },
    { key: 'questions',     label: 'Questions',       icon: HelpCircle,    total: 28,   emoji: '❓', color: '#a855f7', category: 'examination', description: 'MCQ questions with options and correct answers' },
    { key: 'notifications', label: 'Notifications',   icon: Bell,          total: null, emoji: '🔔', color: '#eab308', category: 'system', description: 'Welcome notifications for all seeded users' },
    { key: 'preferences',   label: 'Preferences',     icon: Settings2,     total: null, emoji: '⚙️', color: '#64748b', category: 'system', description: 'Default user preference settings' },
  ];

  // ── NEW: Category grouping ──
  const categories = [
    { key: 'academic', label: 'Academic Structure', icon: GraduationCap, color: '#8b5cf6' },
    { key: 'institution', label: 'Institution', icon: Building2, color: '#f59e0b' },
    { key: 'users', label: 'Users & Accounts', icon: Users, color: '#3b82f6' },
    { key: 'examination', label: 'Examination', icon: ShieldCheck, color: '#ef4444' },
    { key: 'system', label: 'System', icon: Settings2, color: '#64748b' },
  ];

  // ── Semester display info ──
  const semesterDefs = [
    { name: 'First Semester',  months: 'September – January', icon: BookMarked, color: '#3b82f6', short: 'Sem 1', weeks: 18, holidays: 2 },
    { name: 'Second Semester', months: 'February – August', icon: Library,    color: '#10b981', short: 'Sem 2', weeks: 20, holidays: 1 },
  ];

  // ── Credit cap table for display ──
  const creditCapRows = [
    { level: '100L', sem1: 20, sem2: 20, carryOver: 0,  borrowed: 6, totalStudents: 0 },
    { level: '200L', sem1: 24, sem2: 24, carryOver: 6,  borrowed: 6, totalStudents: 0 },
    { level: '300L', sem1: 24, sem2: 24, carryOver: 6,  borrowed: 6, totalStudents: 0 },
    { level: '400L', sem1: 24, sem2: 24, carryOver: 6,  borrowed: 6, totalStudents: 0 },
    { level: '500L', sem1: 21, sem2: 21, carryOver: 6,  borrowed: 6, totalStudents: 0 },
    { level: '600L', sem1: 21, sem2: 21, carryOver: 6,  borrowed: 6, totalStudents: 0 },
    { level: '700L', sem1: 18, sem2: 18, carryOver: 6,  borrowed: 6, totalStudents: 0 },
    { level: '800L', sem1: 18, sem2: 18, carryOver: 6,  borrowed: 6, totalStudents: 0 },
  ];

  // ── NEW: Entity relationship map for preview ──
  const entityRelations = [
    { from: 'levels', to: 'students', type: 'one-to-many', label: 'enrolled at' },
    { from: 'levels', to: 'courses', type: 'one-to-many', label: 'offers' },
    { from: 'colleges', to: 'departments', type: 'one-to-many', label: 'contains' },
    { from: 'departments', to: 'courses', type: 'one-to-many', label: 'offers' },
    { from: 'departments', to: 'staff', type: 'one-to-many', label: 'employs' },
    { from: 'departments', to: 'students', type: 'one-to-many', label: 'enrolls' },
    { from: 'courses', to: 'registrations', type: 'one-to-many', label: 'registered as' },
    { from: 'students', to: 'registrations', type: 'one-to-many', label: 'registers for' },
    { from: 'courses', to: 'exam', type: 'one-to-many', label: 'assessed by' },
    { from: 'exam', to: 'questions', type: 'one-to-many', label: 'contains' },
    { from: 'staff', to: 'exam', type: 'many-to-many', label: 'creates/invigilates' },
  ];

  // ── NEW: Seed history (simulated) ──
  const seedHistory = $state([
    { id: 'seed-001', date: '2026-06-10T14:30:00Z', status: 'success', records: 1247, duration: 8420, triggeredBy: 'admin@mouau.edu.ng' },
    { id: 'seed-002', date: '2026-06-12T09:15:00Z', status: 'success', records: 1247, duration: 7890, triggeredBy: 'admin@mouau.edu.ng' },
  ]);

  function addLog(msg: string, isError = false) {
    const time = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const type = isError ? 'error' : msg.includes('✓') || msg.includes('complete') ? 'success' : 'info';
    logs = [...logs, { time, msg, type }];
    if (isError) console.error(msg);
  }

  function resetProgress() {
    progress = { current: 0, total: seedSteps.length, step: '', detail: '' };
    logs = [];
    seedResults = [];
    showLogs = true;
    form = null;
    seedMetrics = { startTime: Date.now(), endTime: null, recordsPerSecond: 0, peakMemory: 0, currentMemory: 0, estimatedTimeRemaining: 0 };
  }

  // ── NEW: Heartbeat monitoring ──
  function startHeartbeat() {
    const interval = setInterval(() => {
      if (!seeding) {
        clearInterval(interval);
        return;
      }
      const now = Date.now();
      if (seedMetrics.startTime) {
        const elapsed = now - seedMetrics.startTime;
        const estimatedTotal = (elapsed / Math.max(progress.current, 1)) * progress.total;
        seedMetrics.estimatedTimeRemaining = Math.max(0, estimatedTotal - elapsed);
        seedMetrics.recordsPerSecond = Math.round((progress.current / elapsed) * 1000);
      }
      lastHeartbeat = new Date();
    }, 1000);
    return () => clearInterval(interval);
  }

  function startSSE() {
    if (eventSource) eventSource.close();
    connectionStatus = 'connecting';
    eventSource = new EventSource('/api/seed-progress');
    let reconnectAttempts = 0;
    let heartbeatInterval: ReturnType<typeof startHeartbeat>;

    eventSource.onopen = () => {
      connectionStatus = 'connected';
      connectionLatency = Date.now() - (seedMetrics.startTime || Date.now());
      addLog('Connected to real-time progress stream');
      reconnectAttempts = 0;
      heartbeatInterval = startHeartbeat();
    };

    eventSource.onmessage = (event) => {
      const d = JSON.parse(event.data);
      if (d.type === 'progress') {
        const stepIndex = seedSteps.findIndex(s => s.key === d.step);
        if (stepIndex !== -1) {
          progress.current = stepIndex + 1;
          progress.step = d.message;
          progress.detail = d.detail || '';
        }
        addLog(`${d.emoji || '●'} ${d.message}${d.detail ? ` — ${d.detail}` : ''}`);
      } else if (d.type === 'complete') {
        progress.current = seedSteps.length;
        seedMetrics.endTime = Date.now();
        addLog(`✨ ${d.message}`);
        seeding = false;
        connectionStatus = 'disconnected';
        eventSource?.close();
        if (heartbeatInterval) heartbeatInterval();
        setTimeout(() => window.location.reload(), 1500);
      } else if (d.type === 'error') {
        addLog(`Error: ${d.message}`, true);
        seeding = false;
        connectionStatus = 'error';
        eventSource?.close();
        if (heartbeatInterval) heartbeatInterval();
      }
    };

    eventSource.onerror = () => {
      connectionStatus = 'error';
      if (reconnectAttempts < 3) {
        reconnectAttempts++;
        addLog(`Connection lost, reconnecting... (${reconnectAttempts}/3)`, true);
        setTimeout(() => startSSE(), 2000);
      } else {
        addLog('Failed to maintain progress connection. Please refresh.', true);
        seeding = false;
        connectionStatus = 'disconnected';
        eventSource?.close();
        if (heartbeatInterval) heartbeatInterval();
      }
    };
  }

  // ── NEW: Filtered logs ──
  let filteredLogs = $derived(
    logFilter === 'all' ? logs :
    logs.filter(l => l.type === logFilter)
  );

  // ── NEW: Toggle step expansion ──
  function toggleStep(index: number) {
    const next = new Set(expandedSteps);
    if (next.has(index)) next.delete(index);
    else next.add(index);
    expandedSteps = next;
  }

  function getStepStatus(index: number, current: number) {
    if (index < current) return 'completed';
    if (index === current) return 'active';
    return 'pending';
  }

  function getTotalRecords() {
    return seedSteps.reduce((acc, step) => acc + (step.total || 0), 0);
  }

  // ── NEW: Format duration ──
  function formatDuration(ms: number) {
    if (ms < 1000) return `${ms}ms`;
    if (ms < 60000) return `${(ms / 1000).toFixed(1)}s`;
    const mins = Math.floor(ms / 60000);
    const secs = ((ms % 60000) / 1000).toFixed(0);
    return `${mins}m ${secs}s`;
  }

  // ── NEW: Copy logs to clipboard ──
  async function copyLogs() {
    const text = logs.map(l => `[${l.time}] ${l.msg}`).join('\n');
    await navigator.clipboard.writeText(text);
    addLog('📋 Logs copied to clipboard');
  }

  // ── NEW: Export seed report ──
  function exportReport() {
    const report = {
      timestamp: new Date().toISOString(),
      status: form?.success ? 'success' : form?.error ? 'failed' : 'incomplete',
      steps: seedSteps.map((s, i) => ({
        ...s,
        status: getStepStatus(i, progress.current)
      })),
      logs: logs,
      metrics: seedMetrics,
      counts: data.counts
    };
    const blob = new Blob([JSON.stringify(report, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `seed-report-${new Date().toISOString().split('T')[0]}.json`;
    a.click();
    URL.revokeObjectURL(url);
    addLog('📄 Seed report exported');
  }

  // ── NEW: Simulate data preview (would be real API call) ──
  async function loadPreview(entity: string) {
    selectedEntity = entity;
    previewLoading = true;
    // Simulate API delay
    await new Promise(r => setTimeout(r, 600));
    previewData = {
      ...previewData,
      [entity]: generateMockPreview(entity)
    };
    previewLoading = false;
  }

  function generateMockPreview(entity: string): any[] {
    // Mock data based on entity type
    const mocks: Record<string, any[]> = {
      levels: [
        { id: 1, level: 100, name: '100 Level', isDefault: true, students: 12 },
        { id: 2, level: 200, name: '200 Level', isDefault: true, students: 8 },
        { id: 3, level: 300, name: '300 Level', isDefault: true, students: 6 },
      ],
      colleges: [
        { id: 1, name: 'College of Engineering', code: 'CEET', departments: 6 },
        { id: 2, name: 'College of Natural Science', code: 'COLNAS', departments: 4 },
      ],
      courses: [
        { id: 1, code: 'CSC101', title: 'Intro to Computer Science', credits: 3, semester: 1 },
        { id: 2, code: 'CSC301', title: 'Data Structures', credits: 3, semester: 1 },
      ]
    };
    return mocks[entity] || [{ message: 'Preview data not available for this entity' }];
  }

  // ── NEW: Keyboard shortcuts ──
  $effect(() => {
    const handler = (e: KeyboardEvent) => {
      if (e.key === 'l' && e.ctrlKey) { e.preventDefault(); showLogs = !showLogs; }
      if (e.key === 'r' && e.ctrlKey && !seeding) { e.preventDefault(); window.location.reload(); }
      if (e.key === 's' && e.ctrlKey && !seeding && !resetting) { e.preventDefault(); document.querySelector<HTMLButtonElement>('.seed-btn')?.click(); }
    };
    window.addEventListener('keydown', handler);
    return () => window.removeEventListener('keydown', handler);
  });
</script>

