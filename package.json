{
	"name": "mouau-etest",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "prisma generate && prisma migrate deploy && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:migrate": "prisma migrate dev && prisma generate",
		"db:generate": "prisma generate",
		"db:studio": "prisma studio",
		"push": "prisma db push && prisma generate",
		"db:fresh": "prisma db push && prisma generate && tsx prisma/seed.ts",
		"seed:all": "prisma migrate dev && tsx prisma/seed.ts",
		"initSetup": "prisma migrate reset --force && prisma db push && tsx prisma/apply-sql.ts && prisma generate",
		"reset": "prisma migrate reset --force && prisma db push && prisma generate",
		"initSchema": "prisma db push && tsx prisma/apply-sql.ts && prisma generate",
		"db:seed": "tsx prisma/seed.ts",
		"studio": "prisma studio",
		"db:setup": "prisma db push && pnpm initSchema && pnpm db:seed",
		"copy:models": "node scripts/copy-human-models.js",
		"download:models": "node scripts/download-models.js",
		"postinstall": "pnpm prisma generate && pnpm run copy:models"
	},
