// MOUAU eTest — Prisma schema
// prisma · postgresql
//
// Commands:
//   pnpm prisma migrate dev --name <name>
//   pnpm prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  lecturer
  invigilator
  student
}

enum ExamStatus {
  draft
  scheduled
  active
  completed
  cancelled
}

enum QuestionType {
  mcq
  fill_in_the_blank
}

enum FlagType {
  tab_switch
  window_blur
  fullscreen_exit
  copy_attempt
  devtools_open
  screenshot_attempt
  multiple_faces
  no_face_detected
  face_mismatch
  invigilator_manual
}

enum ViolationAction {
  warning
  invigilator_alerted
  exam_paused
  auto_submitted
}

enum ApiScope {
  read_users
  write_users
  read_exams
  write_exams
  read_results
  read_reports
  read_violations
  write_violations
  admin_full
}

enum ApiKeyStatus {
  active
  revoked
  expired
}

enum NotificationType {
  info
  warning
  alert
  error
  critical
}

// Risk Level enum
enum RiskLevel {
  low
  medium
  high
  critical
}

enum RegistrationType {
  normal
  carry_over
  borrowed
}

enum RegistrationStatus {
  pending
  approved
  rejected
  withdrawn
}

enum Gender {
  male
  female
  non_binary
  prefer_not_to_say
  required
}

// ─── Institutional hierarchy ──────────────────────────────────────────────────

model College {
  id           Int     @id @default(autoincrement())
  name         String
  abbreviation String?
  code         String? @unique

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  departments Department[]
  users       User[]

  @@unique([name])
  @@map("colleges")
}

model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collegeId Int      @map("college_id")
  name      String
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  college         College          @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  users           User[]
  courses         Course[]
  programmes      Programme[]
  examDepartments ExamDepartment[]

  @@unique([name, collegeId])
  @@index([collegeId])
  @@map("departments")
}

model Level {
  id        Int      @id @default(autoincrement())
  level     Int      @unique
  name      String? // Optional: "100 Level", "200 Level", etc.
  isDefault Boolean  @default(false)
  order     Int      @default(0) // For custom sorting
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  users           User[]                @relation("UserLevel")
  exams           Exam[]                @relation("ExamLevels")
  registrations   CourseRegistration[]
  examLevels      ExamLevel[]
  semesterConfigs LevelSemesterConfig[]

  @@map("levels")
}

model LevelSemesterConfig {
  id           Int      @id @default(autoincrement())
  levelId      Int      @map("level_id")
  semester     Int      @db.SmallInt // 1 or 2
  maxCredits   Int      @default(24) @map("max_credits") @db.SmallInt
  maxCarryOver Int      @default(6) @map("max_carry_over") @db.SmallInt
  maxBorrowed  Int      @default(6) @map("max_borrowed") @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([levelId, semester])
  @@map("level_semester_configs")
}

model AcademicSemester {
  id          Int      @id @default(autoincrement())
  session     String
  semester    Int      @db.SmallInt
  label       String?
  startDate   DateTime @map("start_date") @db.Timestamptz()
  endDate     DateTime @map("end_date") @db.Timestamptz()
  isActive    Boolean  @default(false) @map("is_active")
  regOpen     Boolean  @default(true) @map("reg_open")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  createdById String?  @map("created_by_id") @db.Uuid

  createdBy User? @relation("SemesterCreatedBy", fields: [createdById], references: [id])

  @@unique([session, semester])
  @@map("academic_semesters")
}

// ─── Users ────────────────────────────────────────────────────────────────────

// User model - corrected Level relationship
model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  fullName      String   @map("full_name")
  passwordHash  String   @map("password_hash")
  role          UserRole
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  emailVerified Boolean  @default(false) @map("emailverified)")

  // ── Contact ──────────────────────────────────────────────────────────────
  phone   String?
  title   String?
  address String?

  gender      Gender   @default(required) @map("gender")
  dateOfBirth DateTime @default(now()) @map("dateofbirth") @db.Timestamptz()

  // ── Academic identity ─────────────────────────────────────────────────────
  matricNumber String? @unique @map("matric_number")
  staffId      String? @unique @map("staff_id")
  jambRegNo    String? @unique @map("jamb_reg_no")

  // Level - reference to Level model (one-to-many: one level has many users)
  levelId Int?    @map("level_id")
  level   Level?  @relation("UserLevel", fields: [levelId], references: [id])
  session String?

  // ── Institution ───────────────────────────────────────────────────────────
  collegeId    Int?        @map("college_id")
  college      College?    @relation(fields: [collegeId], references: [id])
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id])
  programmeId  String?     @db.Uuid
  programme    Programme?  @relation(fields: [programmeId], references: [id])

  // ── Profile ───────────────────────────────────────────────────────────────
  photoUrl      String? @map("photo_url")
  twitter       String?
  linkedin      String?
  github        String?
  bio           String?
  nationality   String?
  stateoforigin String?
  lga           String?

  // ── Receipt audit trail ───────────────────────────────────────────────────
  receiptNo     String? @map("receipt_no")
  receiptRef    String? @map("receipt_ref")
  receiptSource String? @map("receipt_source")

  // ── Suspension audit ──────────────────────────────────────────────────────
  isSuspended   Boolean   @default(false) @map("is_suspended")
  suspendedAt   DateTime? @map("suspended_at") @db.Timestamptz()
  suspendedById String?   @map("suspended_by_id")

  // ── Face enrollment ───────────────────────────────────────────────────────
  faceDescriptor FaceDescriptor?

  // ── Relations ─────────────────────────────────────────────────────────────
  authSessions        AuthSession[]
  courseRegistrations CourseRegistration[]
  createdExams        Exam[]               @relation("LecturerExams")
  examSessions        ExamSession[]        @relation("StudentSessions")
  invigilatedSessions ExamSession[]        @relation("InvigilatorSessions")
  examInvigilators    ExamInvigilator[]
  examResults         ExamResult[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  createdApiKeys      ApiKey[]             @relation("ApiKeyCreatedBy")
  revokedApiKeys      ApiKey[]             @relation("ApiKeyRevokedBy")
  userPreferences     UserPreference[]
  createdSemesters    AcademicSemester[]   @relation("SemesterCreatedBy")

  // ─── Face verification & similarity ───────────────────────────────────────
  verificationLogs  FaceVerificationLog[] @relation("StudentVerifications")
  faceSimilaritiesA FaceSimilarity[]      @relation("StudentA")
  faceSimilaritiesB FaceSimilarity[]      @relation("StudentB")
  passwordResets    PasswordReset[]

  @@index([role])
  @@index([collegeId])
  @@index([departmentId])
  @@index([matricNumber])
  @@index([jambRegNo])
  @@index([staffId])
  @@index([isSuspended])
  @@index([levelId])
  @@map("users")
}

model PasswordReset {
  token     String    @id
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

// ─── Face Descriptors ─────────────────────────────────────────────────────────
//
// Stores the 128-float face embedding produced by face-api / vladmandic.
// Kept in its own table so:
//   • it can be wiped/re-enrolled without touching the user row
//   • the descriptor column (large JSON array) doesn't bloat user queries
//   • cascade delete keeps it clean when a user is removed
//
// descriptor is stored as a JSON array of 128 floats.
// If you later add pgvector, swap the column type to vector(128) and
// update faces.ts accordingly — the API surface stays the same.

model FaceDescriptor {
  studentId           String   @id @map("student_id") @db.Uuid
  descriptor          Json // 128-element float array — e.g. [0.123, -0.456, ...]
  enrolledAt          DateTime @default(now()) @map("enrolled_at") @db.Timestamptz()
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  embedding_dimension Int      @default(512) @map("embedding_dimension")
  student             User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("face_descriptors")
}

// Face similarity for academic integrity
model FaceSimilarity {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId             String    @map("exam_id") @db.Uuid
  studentAId         String    @map("student_a_id") @db.Uuid
  studentBId         String    @map("student_b_id") @db.Uuid
  similarityScore    Decimal   @map("similarity_score") @db.Decimal(5, 3)
  sharedAnswers      Int       @default(0) @map("shared_answers") @db.SmallInt
  sharedWrongAnswers Int       @default(0) @map("shared_wrong_answers") @db.SmallInt
  totalQuestions     Int       @default(0) @map("total_questions") @db.SmallInt
  riskLevel          RiskLevel @map("risk_level")
  generatedAt        DateTime  @default(now()) @map("generated_at") @db.Timestamptz()

  exam     Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentA User @relation("StudentA", fields: [studentAId], references: [id])
  studentB User @relation("StudentB", fields: [studentBId], references: [id])

  @@unique([examId, studentAId, studentBId])
  @@index([examId])
  @@index([examId, riskLevel])
  @@index([examId, similarityScore(sort: Desc)])
  @@index([examId, studentAId, studentBId])
  @@map("face_similarity")
}

// Face verification audit logs
model FaceVerificationLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId       String   @map("student_id") @db.Uuid
  examId          String?  @map("exam_id") @db.Uuid
  similarityScore Decimal? @map("similarity_score") @db.Decimal(5, 2)
  distance        Decimal? @db.Decimal(6, 4)
  success         Boolean
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  verifiedAt      DateTime @default(now()) @map("verified_at") @db.Timestamptz()

  student User  @relation("StudentVerifications", fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam? @relation(fields: [examId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([examId])
  @@index([verifiedAt(sort: Desc)])
  @@map("face_verification_logs")
}

// ─── Auth Sessions ────────────────────────────────────────────────────────────

model AuthSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("auth_sessions")
}

// ─── Courses ──────────────────────────────────────────────────────────────────

model Course {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId String   @map("department_id") @db.Uuid
  code         String   @unique
  title        String
  creditUnits  Int      @default(2) @map("credit_units") @db.SmallInt
  level        Int?     @db.SmallInt
  semester     Int?     @db.SmallInt // ← ADD THIS: 1 or 2
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  department    Department           @relation(fields: [departmentId], references: [id])
  registrations CourseRegistration[]
  exams         Exam[]
  programme     Programme?           @relation(fields: [programmeId], references: [id])
  programmeId   String?              @db.Uuid

  @@map("courses")
}

model CourseRegistration {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId        String             @map("student_id") @db.Uuid
  courseId         String             @map("course_id") @db.Uuid
  session          String
  levelId          Int?               @map("level_id")
  semester         Int                @db.SmallInt
  registrationType RegistrationType   @default(normal) @map("registration_type")
  status           RegistrationStatus @default(pending) @map("status") // Add this
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  level   Level? @relation(fields: [levelId], references: [id])

  @@unique([studentId, courseId, session, semester])
  @@map("course_registrations")
}

model Programme {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId  String   @map("department_id") @db.Uuid
  name          String
  code          String?  @unique
  durationYears Int      @default(4) @map("duration_years") @db.SmallInt
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users      User[]
  courses    Course[]

  @@unique([name, departmentId])
  @@index([departmentId])
  @@map("programmes")
}

// ─── Exams ────────────────────────────────────────────────────────────────────

model Exam {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId           String     @map("course_id") @db.Uuid
  createdBy          String     @map("created_by") @db.Uuid
  title              String
  instructions       String?
  durationMinutes    Int        @default(60) @map("duration_minutes") @db.SmallInt
  totalMarks         Int        @default(100) @map("total_marks") @db.SmallInt
  passMark           Int        @default(40) @map("pass_mark") @db.SmallInt
  status             ExamStatus @default(draft)
  scheduledStart     DateTime?  @map("scheduled_start") @db.Timestamptz()
  scheduledEnd       DateTime?  @map("scheduled_end") @db.Timestamptz()
  allowLateEntry     Boolean    @default(false) @map("allow_late_entry")
  lateEntryMinutes   Int        @default(10) @map("late_entry_minutes") @db.SmallInt
  randomizeQuestions Boolean    @default(true) @map("randomize_questions")
  randomizeOptions   Boolean    @default(true) @map("randomize_options")
  questionsToPresent Int        @default(0) @map("questions_to_present") @db.SmallInt // ← NEW
  showResultAfter    Boolean    @default(false) @map("show_result_after")
  maxViolations      Int        @default(5) @map("max_violations") @db.SmallInt
  session            String
  department         String?
  semester           Int        @db.SmallInt
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  course               Course                @relation(fields: [courseId], references: [id])
  lecturer             User                  @relation("LecturerExams", fields: [createdBy], references: [id])
  questions            Question[]
  examSessions         ExamSession[]
  invigilators         ExamInvigilator[]
  examResults          ExamResult[]
  levels               Level[]               @relation("ExamLevels")
  examLevels           ExamLevel[]
  faceSimilarities     FaceSimilarity[]
  faceVerificationLogs FaceVerificationLog[]
  examDepartments      ExamDepartment[]

  @@index([courseId])
  @@index([status])
  @@map("exams")
}

model ExamLevel {
  examId  String @map("exam_id") @db.Uuid
  levelId Int    @map("level_id")

  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@id([examId, levelId])
  @@map("exam_levels")
}

model ExamDepartment {
  examId       String @map("exam_id") @db.Uuid
  departmentId String @map("department_id") @db.Uuid

  exam       Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([examId, departmentId])
  @@map("exam_departments")
}

// ─── Questions ────────────────────────────────────────────────────────────────

model Question {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId     String       @map("exam_id") @db.Uuid
  type       QuestionType
  body       String
  topic      String? // e.g. "Thermodynamics", "Algebra" — drives weakness/strength analysis in results
  imageUrl   String?      @map("image_url")
  marks      Int          @default(1) @db.SmallInt
  orderIndex Int?         @map("order_index") @db.SmallInt
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  exam                 Exam                   @relation(fields: [examId], references: [id], onDelete: Cascade)
  options              QuestionOption[]
  fitbAnswers          FitbAnswer[]
  studentAnswers       StudentAnswer[]
  sessionQuestionOrder SessionQuestionOrder[]
  sessionOptionOrder   SessionOptionOrder[]

  @@index([examId])
  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  optionText String  @map("option_text")
  isCorrect  Boolean @default(false) @map("is_correct")
  orderIndex Int?    @map("order_index") @db.SmallInt

  question           Question             @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswers     StudentAnswer[]
  sessionOptionOrder SessionOptionOrder[]

  @@map("question_options")
}

model FitbAnswer {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId     String  @map("question_id") @db.Uuid
  acceptedAnswer String  @map("accepted_answer")
  isPrimary      Boolean @default(false) @map("is_primary")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("fitb_answers")
}

// ─── Exam Sessions ────────────────────────────────────────────────────────────

model ExamSession {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId            String    @map("exam_id") @db.Uuid
  studentId         String    @map("student_id") @db.Uuid
  invigilatorId     String?   @map("invigilator_id") @db.Uuid
  status            String    @default("not_started")
  startedAt         DateTime? @map("started_at") @db.Timestamptz()
  submittedAt       DateTime? @map("submitted_at") @db.Timestamptz()
  timeRemainingSecs Int?      @map("time_remaining_secs")
  ipAddress         String?   @map("ip_address")
  deviceInfo        String?   @map("device_info")
  score             Decimal?  @db.Decimal(5, 2)
  isGraded          Boolean   @default(false) @map("is_graded")
  violationCount    Int       @default(0) @map("violation_count") @db.SmallInt
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  exam                 Exam                   @relation(fields: [examId], references: [id])
  student              User                   @relation("StudentSessions", fields: [studentId], references: [id])
  invigilator          User?                  @relation("InvigilatorSessions", fields: [invigilatorId], references: [id])
  studentAnswers       StudentAnswer[]
  violations           Violation[]
  examResult           ExamResult?
  sessionQuestionOrder SessionQuestionOrder[]
  sessionOptionOrder   SessionOptionOrder[]

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([status])
  @@map("exam_sessions")
}

model SessionQuestionOrder {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String @map("session_id") @db.Uuid
  questionId   String @map("question_id") @db.Uuid
  displayIndex Int    @map("display_index") @db.SmallInt

  session  ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@map("session_question_order")
}

model SessionOptionOrder {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String @map("session_id") @db.Uuid
  questionId   String @map("question_id") @db.Uuid
  optionId     String @map("option_id") @db.Uuid
  displayIndex Int    @map("display_index") @db.SmallInt

  session  ExamSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question       @relation(fields: [questionId], references: [id])
  option   QuestionOption @relation(fields: [optionId], references: [id])

  @@unique([sessionId, optionId])
  @@map("session_option_order")
}

// ─── Student Answers ──────────────────────────────────────────────────────────

model StudentAnswer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId      String   @map("session_id") @db.Uuid
  questionId     String   @map("question_id") @db.Uuid
  selectedOption String?  @map("selected_option") @db.Uuid
  textAnswer     String?  @map("text_answer")
  isCorrect      Boolean? @map("is_correct")
  marksEarned    Decimal  @default(0) @map("marks_earned") @db.Decimal(4, 2)
  timeSpentSecs  Int?     @map("time_spent_secs")
  answeredAt     DateTime @default(now()) @map("answered_at") @db.Timestamptz()

  session  ExamSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id])
  option   QuestionOption? @relation(fields: [selectedOption], references: [id])

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@map("student_answers")
}

// ─── Violations ───────────────────────────────────────────────────────────────

model Violation {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String           @map("session_id") @db.Uuid
  flagType    FlagType         @map("flag_type")
  actionTaken ViolationAction? @map("action_taken")
  note        String?
  flaggedAt   DateTime         @default(now()) @map("flagged_at") @db.Timestamptz()

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([flagType])
  @@map("violations")
}

// ─── Invigilator Assignments ──────────────────────────────────────────────────

model ExamInvigilator {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId        String   @map("exam_id") @db.Uuid
  invigilatorId String   @map("invigilator_id") @db.Uuid
  assignedAt    DateTime @default(now()) @map("assigned_at") @db.Timestamptz()

  exam        Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  invigilator User @relation(fields: [invigilatorId], references: [id])

  @@unique([examId, invigilatorId])
  @@map("exam_invigilators")
}

// ─── Results ──────────────────────────────────────────────────────────────────

model ExamResult {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId      String    @unique @map("session_id") @db.Uuid
  studentId      String    @map("student_id") @db.Uuid
  examId         String    @map("exam_id") @db.Uuid
  totalQuestions Int?      @map("total_questions") @db.SmallInt
  answered       Int?      @db.SmallInt
  correct        Int?      @db.SmallInt
  score          Decimal?  @db.Decimal(5, 2)
  percentage     Decimal?  @db.Decimal(5, 2)
  passed         Boolean?
  grade          String?   @db.Char(2)
  violationCount Int       @default(0) @map("violation_count") @db.SmallInt
  timeTakenSecs  Int?      @map("time_taken_secs")
  submittedAt    DateTime? @map("submitted_at") @db.Timestamptz()
  generatedAt    DateTime  @default(now()) @map("generated_at") @db.Timestamptz()

  session ExamSession @relation(fields: [sessionId], references: [id])
  student User        @relation(fields: [studentId], references: [id])
  exam    Exam        @relation(fields: [examId], references: [id])

  @@index([examId])
  @@index([studentId])
  @@map("exam_results")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String?
  entityId  String?  @map("entity_id") @db.Uuid
  metadata  Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ─── API Keys ────────────────────────────────────────────────────────────────
model ApiKey {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String // human-readable label
  keyHash      String       @unique @map("key_hash") // bcrypt hash of the raw key
  keyPrefix    String       @map("key_prefix") // first 8 chars shown in UI  e.g. "mk_live_"
  scopes       ApiScope[] // array of granted scopes
  status       ApiKeyStatus @default(active)
  createdById  String       @map("created_by_id") @db.Uuid
  lastUsedAt   DateTime?    @map("last_used_at") @db.Timestamptz()
  expiresAt    DateTime?    @map("expires_at") @db.Timestamptz()
  revokedAt    DateTime?    @map("revoked_at") @db.Timestamptz()
  revokedById  String?      @map("revoked_by_id") @db.Uuid
  ipWhitelist  String[]     @default([]) @map("ip_whitelist") // optional CIDR list
  requestCount Int          @default(0) @map("request_count")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  createdBy User  @relation("ApiKeyCreatedBy", fields: [createdById], references: [id])
  revokedBy User? @relation("ApiKeyRevokedBy", fields: [revokedById], references: [id])

  accessLogs ApiAccessLog[]

  @@index([status])
  @@index([createdById])
  @@map("api_keys")
}

model ApiAccessLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyId      String   @map("key_id") @db.Uuid
  endpoint   String
  method     String   @db.VarChar(10)
  statusCode Int      @map("status_code") @db.SmallInt
  ipAddress  String?  @map("ip_address")
  durationMs Int?     @map("duration_ms") @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  key ApiKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId])
  @@index([createdAt])
  @@map("api_access_logs")
}

model UserPreference {
  userId    String   @id @map("user_id") @db.Uuid
  prefs     Json     @default("{}") // flexible JSON object for various preferences
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
