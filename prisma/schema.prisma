// ============================================================
// MOUAU eTEST — Prisma Schema
// Domain 1: Auth & Users + Academic Structure
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum StaffRole {
  SUPER_ADMIN
  VC
  DVC
  REGISTRAR
  UNIVERSITY_EXAM_OFFICER
  UNIVERSITY_COURSE_COORDINATOR
  DEAN
  HOD
  COLLEGE_EXAM_OFFICER
  COLLEGE_COORDINATOR
  DEPARTMENT_EXAM_OFFICER
  DEPARTMENT_COORDINATOR
  LECTURER
  INVIGILATOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  EXPELLED
  GRADUATED
  WITHDRAWN
  DEFERRED
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  RETIRED
}

enum SemesterType {
  FIRST
  SECOND
  SUMMER
}

enum ProgrammeType {
  UNDERGRADUATE
  POSTGRADUATE_DIPLOMA
  MASTERS
  PHD
  CERTIFICATE
  DIPLOMA
}

enum AcademicSessionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum CourseStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum CourseType {
  COMPULSORY
  ELECTIVE
  GENERAL_STUDIES
  CARRYOVER_ELIGIBLE
}

// ============================================================
// RBAC — Security,Roles & Permission
// ============================================================

model OtpRecord {
  id        String   @id @default(cuid())
  email     String
  otp       String
  type      String   // 'STAFF_RESET' | 'STUDENT_RESET' | 'STAFF_2FA'
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, type])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userType   String    // "staff" | "student"
  staffId    String?
  studentId  String?
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  staff   Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userType, staffId, studentId])
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "exam:create", "result:release"
  description String?
  group       String // e.g. "Examination", "Result", "Student"
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // mirrors StaffRole values
  displayName String
  description String?
  isSystem    Boolean  @default(true) // system roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  staffRoles  StaffRoleAssignment[]
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model StaffRoleAssignment {
  id         String    @id @default(cuid())
  staffId    String
  roleId     String
  assignedBy String?
  assignedAt DateTime  @default(now())
  expiresAt  DateTime?
  isActive   Boolean   @default(true)

  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner Staff? @relation("RoleAssigner", fields: [assignedBy], references: [id])

  @@unique([staffId, roleId])
}

// ============================================================
// ACADEMIC STRUCTURE
// ============================================================

model University {
  id        String   @id @default(cuid())
  name      String
  shortName String   @unique
  address   String?
  website   String?
  email     String?
  phone     String?
  logo      String? // file path/url
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  colleges College[]
}

model College {
  id           String   @id @default(cuid())
  universityId String
  name         String
  shortName    String
  code         String   @unique
  email        String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university  University   @relation(fields: [universityId], references: [id])
  departments Department[]
  staff       Staff[]

  @@unique([universityId, shortName])
}

model Department {
  id        String   @id @default(cuid())
  collegeId String
  name      String
  shortName String
  code      String   @unique
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college     College                 @relation(fields: [collegeId], references: [id])
  programmes  Programme[]
  staff       Staff[]
  students    Student[]
  courses     Course[]
  eligibility AssessmentEligibility[]

  @@unique([collegeId, shortName])
}

model Programme {
  id            String        @id @default(cuid())
  departmentId  String
  name          String
  shortName     String
  type          ProgrammeType @default(UNDERGRADUATE)
  durationYears Int           @default(4)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  students   Student[]

  @@unique([departmentId, shortName])
}

// Represents a level (100, 200, ... 700) — no hardcoded values
model Level {
  id        String   @id @default(cuid())
  name      Int      @unique // 100, 200, 300, ...
  label     String // "100 Level", "Postgraduate", etc.
  createdAt DateTime @default(now())

  courseRegistrations CourseRegistration[]
  courses             Course[]
  students            Student[]               @relation("CurrentLevel")
  eligibility         AssessmentEligibility[]
}

model AcademicSession {
  id        String                @id @default(cuid())
  name      String                @unique // e.g. "2024/2025"
  startDate DateTime
  endDate   DateTime
  status    AcademicSessionStatus @default(UPCOMING)
  isCurrent Boolean               @default(false)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  semesters           Semester[]
  courseRegistrations CourseRegistration[]
  transcriptEntries   TranscriptEntry[]
}

model Semester {
  id         String       @id @default(cuid())
  sessionId  String
  type       SemesterType
  startDate  DateTime
  endDate    DateTime
  regOpenAt  DateTime? // when registration opens
  regCloseAt DateTime? // when registration closes
  isCurrent  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  session             AcademicSession      @relation(fields: [sessionId], references: [id])
  courseRegistrations CourseRegistration[]
  courses             CourseOffering[]

  @@unique([sessionId, type])
}

// ============================================================
// COURSES
// ============================================================

model Course {
  id           String       @id @default(cuid())
  departmentId String
  levelId      String
  code         String       @unique // e.g. "CSC301"
  title        String
  creditUnits  Int          @default(2)
  type         CourseType   @default(COMPULSORY)
  status       CourseStatus @default(ACTIVE)
  description  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  department        Department           @relation(fields: [departmentId], references: [id])
  level             Level                @relation(fields: [levelId], references: [id])
  offerings         CourseOffering[]
  registrations     CourseRegistration[]
  questions         Question[]
  assessments       Assessment[]
  transcriptEntries TranscriptEntry[]
}

// A specific offering of a course in a semester (who teaches it, exam details)
model CourseOffering {
  id         String   @id @default(cuid())
  courseId   String
  semesterId String
  lecturerId String? // primary lecturer
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course   Course   @relation(fields: [courseId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])
  lecturer Staff?   @relation("CourseOfferings", fields: [lecturerId], references: [id])

  @@unique([courseId, semesterId])
}

// ============================================================
// COURSE REGISTRATION
// ============================================================

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RegistrationType {
  NORMAL // current level courses
  CARRY_OVER // retaking a failed course
  EXTRA // additional course (with approval)
}

model CourseRegistration {
  id           String             @id @default(cuid())
  studentId    String
  courseId     String
  sessionId    String
  semesterId   String
  levelId      String
  type         RegistrationType   @default(NORMAL)
  status       RegistrationStatus @default(PENDING)
  editCount    Int                @default(0) // max 3
  approvedBy   String?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectedNote String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  student  Student         @relation(fields: [studentId], references: [id])
  course   Course          @relation(fields: [courseId], references: [id])
  session  AcademicSession @relation(fields: [sessionId], references: [id])
  semester Semester        @relation(fields: [semesterId], references: [id])
  level    Level           @relation(fields: [levelId], references: [id])
  approver Staff?          @relation("RegistrationApprover", fields: [approvedBy], references: [id])

  @@unique([studentId, courseId, sessionId, semesterId])
}

// ============================================================
// STAFF
// ============================================================

model Staff {
  id                 String      @id @default(cuid())
  staffNumber        String      @unique
  email              String      
  emailHash          String      @unique
  passwordHash       String
  firstName          String
  lastName           String
  otherNames         String?
  phone              String?
  gender             Gender?
  avatar             String?
  primaryRole        StaffRole // their main role in the system
  collegeId          String?
  departmentId       String?
  status             StaffStatus @default(ACTIVE)
  mustChangePassword Boolean     @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  college    College?    @relation(fields: [collegeId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  // RBAC
  roleAssignments StaffRoleAssignment[]
  assignedRoles   StaffRoleAssignment[] @relation("RoleAssigner")

  // Relations to other domains (added as we build)
  authoredQuestions Question[]           @relation("QuestionAuthor")
  sessions          StaffSession[]
  courseOfferings   CourseOffering[]     @relation("CourseOfferings")
  approvedRegs      CourseRegistration[] @relation("RegistrationApprover")
  auditLogs         AuditLog[]
  passwordResets PasswordResetToken[]

  createdAssessments Assessment[]            @relation("AssessmentAuthor")
  invigilations      AssessmentInvigilator[]
  gradedAnswers      StudentAnswer[]         @relation("AnswerGrader")
  releasedResults    AssessmentResult[]      @relation("ResultReleaser")
  resultRevisions    ResultRevision[]

  @@index([emailHash])
  @@index([staffNumber])
  @@index([collegeId, departmentId, primaryRole, status, lastLoginAt])
}

model StaffSession {
  id           String   @id @default(cuid())
  staffId      String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  refreshTokenExpiresAt DateTime?
  lastActiveAt DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ============================================================
// STUDENT
// ============================================================

model Student {
  id                 String        @id @default(cuid())
  matricNumber       String        @unique
  jambRegNo           String  @unique
  receiptNo           String?
  receiptRef          String?
  receiptSource       String?
  registrationSession String?
  email              String        @unique
  emailHash          String        @unique
  passwordHash       String
  firstName          String
  lastName           String
  otherNames         String?
  phone              String?
  gender             Gender?
  avatar             String?
  dateOfBirth        DateTime?
  departmentId       String
  programmeId        String
  currentLevelId     String
  entryYear          Int // e.g. 2026
  status             StudentStatus @default(ACTIVE)
  // face enrollment — descriptor stored separately for security
  faceEnrolledAt     DateTime?
  mustChangePassword Boolean       @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  department   Department @relation(fields: [departmentId], references: [id])
  programme    Programme  @relation(fields: [programmeId], references: [id])
  currentLevel Level      @relation("CurrentLevel", fields: [currentLevelId], references: [id])

  // Relations to other domains (added as we build)
  sessions            StudentSession[]
  courseRegistrations CourseRegistration[]
  faceDescriptor      FaceDescriptor?
  notifications       Notification[]
  auditLogs           AuditLog[]
  eligibility        AssessmentEligibility[]
  assessmentSessions AssessmentSession[]
  results            AssessmentResult[]
  transcriptEntries  TranscriptEntry[]
  passwordResets PasswordResetToken[]

  @@index([matricNumber])
  @@index([emailHash])
  @@index([jambRegNo])
  @@index([departmentId, programmeId, entryYear, currentLevelId, phone, status])
}

model StudentSession {
  id                String   @id @default(cuid())
  studentId         String
  token             String   @unique
  refreshToken      String?  @unique
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  expiresAt         DateTime
  refreshTokenExpiresAt DateTime?
  createdAt         DateTime @default(now())
  lastActiveAt      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ============================================================
// FACE RECOGNITION
// ============================================================

model FaceDescriptor {
  id                String   @id @default(cuid())
  studentId         String   @unique
  encryptedData     String // AES-256-GCM encrypted face embedding
  iv                String // encryption IV
  enrolledAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
  enrolledIpAddress String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ============================================================
// NOTIFICATIONS (stub — expanded in notifications domain)
// ============================================================

enum NotificationType {
  REGISTRATION_REMINDER
  MISSING_COURSE_ALERT
  EXAM_SCHEDULE
  FACE_ENROLLMENT_REMINDER
  PAYMENT_REMINDER
  RESULT_RELEASED
  EXAM_STARTING
  VIOLATION_ALERT
  PENDING_APPROVAL
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  studentId String?
  staffId   String?
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  link      String? // optional deep-link
  createdAt DateTime         @default(now())

  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ============================================================
// AUDIT LOG (global — used by all domains)
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  actorType  String // "staff" | "student" | "system"
  staffId    String?
  studentId  String?
  action     String // e.g. "EXAM_SUBMITTED", "RESULT_RELEASED"
  entity     String // table/domain name
  entityId   String?
  beforeData Json? // snapshot before change
  afterData  Json? // snapshot after change
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  staff   Staff?   @relation(fields: [staffId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@index([actorType, staffId])
  @@index([actorType, studentId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ============================================================
// MOUAU eTEST — Domain 2: Assessments + Question Bank
// Append this to prisma/schema.prisma (after Domain 1)
// ============================================================

// ============================================================
// ENUMS
// ============================================================

enum AssessmentType {
  PRACTICE // unlimited attempts, instant feedback
  ASSIGNMENT // due dates, submission, grading
  TEST // 30 marks, face verification
  EXAMINATION // 70 marks, highest security
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  SCHEDULED // published, not yet open
  ACTIVE // currently accepting sessions
  ENDED // past end time
  CANCELLED
}

enum QuestionType {
  SINGLE_CHOICE // one correct answer
  MULTIPLE_CHOICE // multiple correct answers
  TRUE_FALSE
  FILL_BLANK
  MATCHING
  ESSAY
  ORDERING
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum SessionStatus {
  PENDING // created, not yet started
  IN_PROGRESS
  PAUSED // network drop / tab switch
  SUBMITTED
  TIMED_OUT // auto-submitted at time expiry
  DISQUALIFIED
}

enum SubmissionMode {
  MANUAL // student clicked submit
  AUTO_TIME // server auto-submitted on timeout
  AUTO_VIOLATION // auto-submitted due to violations
  FORCE // admin forced submission
}

enum GradeLabel {
  A
  B
  C
  D
  E
  F
}

// ============================================================
// QUESTION BANK
// ============================================================

// Tags for searchability
model QuestionTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  questions QuestionTagMap[]
}

model QuestionTagMap {
  questionId String
  tagId      String

  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
}

model Question {
  id          String          @id @default(cuid())
  createdById String // staff who created it
  courseId    String? // optional — can be global bank
  type        QuestionType
  difficulty  DifficultyLevel @default(MEDIUM)
  body        String // question text (supports markdown)
  explanation String? // shown after answer in practice/assignment
  imageUrl    String?
  audioUrl    String?
  videoUrl    String?
  marks       Decimal         @default(1) @db.Decimal(6, 2)
  isActive    Boolean         @default(true)
  version     Int             @default(1)
  parentId    String? // if this is a revised version

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy Staff      @relation("QuestionAuthor", fields: [createdById], references: [id])
  course    Course?    @relation(fields: [courseId], references: [id])
  parent    Question?  @relation("QuestionVersions", fields: [parentId], references: [id])
  versions  Question[] @relation("QuestionVersions")

  options       QuestionOption[]
  matchPairs    MatchPair[]
  tags          QuestionTagMap[]
  assessmentQs  AssessmentQuestion[]
  answers       StudentAnswer[]
  sessionOrders SessionQuestionOrder[]
}

// For SINGLE_CHOICE, MULTIPLE_CHOICE, TRUE_FALSE
model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  body       String
  imageUrl   String?
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// For MATCHING questions: left side → right side
model MatchPair {
  id         String @id @default(cuid())
  questionId String
  leftItem   String
  rightItem  String
  order      Int    @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ============================================================
// ASSESSMENTS (Exam / Test / Assignment / Practice)
// ============================================================

model Assessment {
  id                    String           @id @default(cuid())
  createdById           String // staff/lecturer
  courseId              String
  type                  AssessmentType
  status                AssessmentStatus @default(DRAFT)
  title                 String
  instructions          String?
  totalMarks            Decimal          @db.Decimal(6, 2) // 70 for Exam, 30 for Test
  passMark              Decimal          @db.Decimal(6, 2) // e.g. 40% of totalMarks
  durationMinutes       Int // how long each session lasts
  startTime             DateTime? // when students can begin
  endTime               DateTime? // after this, no new sessions
  maxAttempts           Int              @default(1) // PRACTICE: 999
  questionCount         Int // how many to pick from pool
  shuffleQuestions      Boolean          @default(true)
  shuffleOptions        Boolean          @default(true)
  showResultImmediately Boolean          @default(false) // PRACTICE/ASSIGNMENT: true
  allowReview           Boolean          @default(false) // can student review answers?
  requireFaceVerify     Boolean          @default(false) // TEST + EXAM: true
  requireLiveness       Boolean          @default(false) // EXAM only: true
  offlineEnabled        Boolean          @default(false) // EXAM only
  fullscreenRequired    Boolean          @default(false) // TEST + EXAM: true
  // Assignment-specific
  dueDate               DateTime?
  allowLateSubmission   Boolean          @default(false)
  latePenaltyPercent    Decimal?         @db.Decimal(5, 2)
  // Exam paper variants (Type A/B/C)
  paperVariants         Int              @default(1)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy Staff  @relation("AssessmentAuthor", fields: [createdById], references: [id])
  course    Course @relation(fields: [courseId], references: [id])

  questions    AssessmentQuestion[]
  sessions     AssessmentSession[]
  invigilators AssessmentInvigilator[]
  eligibility  AssessmentEligibility[]
  results      AssessmentResult[]
}

// The question pool for an assessment — ordered, with per-question mark override
model AssessmentQuestion {
  id            String   @id @default(cuid())
  assessmentId  String
  questionId    String
  order         Int      @default(0) // for drag-reorder in builder
  marksOverride Decimal? @db.Decimal(6, 2) // if null, use question.marks

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
}

// Who is eligible — by department, level, or individual student
model AssessmentEligibility {
  id           String  @id @default(cuid())
  assessmentId String
  departmentId String?
  levelId      String?
  studentId    String? // for individual overrides

  assessment Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  level      Level?      @relation(fields: [levelId], references: [id])
  student    Student?    @relation(fields: [studentId], references: [id])

  @@unique([assessmentId, departmentId, levelId, studentId])
}

// Invigilators assigned to an exam session
model AssessmentInvigilator {
  id           String   @id @default(cuid())
  assessmentId String
  staffId      String
  assignedAt   DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  staff      Staff      @relation(fields: [staffId], references: [id])

  @@unique([assessmentId, staffId])
}

// ============================================================
// ASSESSMENT SESSIONS (one per student per attempt)
// ============================================================

model AssessmentSession {
  id            String        @id @default(cuid())
  assessmentId  String
  studentId     String
  attemptNumber Int           @default(1)
  status        SessionStatus @default(PENDING)
  paperVariant  String? // "A", "B", "C"

  // timing
  startedAt   DateTime?
  submittedAt DateTime?
  expiresAt   DateTime? // startedAt + durationMinutes

  // submission
  submissionMode    SubmissionMode?
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?

  // face verification result
  faceVerifiedAt DateTime?
  faceScore      Float? // cosine similarity at verification

  // server-authoritative timer (seconds remaining at last sync)
  timeRemainingSeconds Int?

  // offline
  isOffline  Boolean   @default(false)
  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessment Assessment        @relation(fields: [assessmentId], references: [id])
  student    Student           @relation(fields: [studentId], references: [id])
  answers    StudentAnswer[]
  violations Violation[]
  result     AssessmentResult?

  // the shuffled question order for this specific session
  questionOrder SessionQuestionOrder[]

  @@unique([assessmentId, studentId, attemptNumber])
  @@index([assessmentId, status])
  @@index([studentId])
}

// The randomised question order for a session
// Stored so student sees same order if they rejoin
model SessionQuestionOrder {
  id          String @id @default(cuid())
  sessionId   String
  questionId  String
  position    Int // 1-based position in this student's paper
  optionOrder Json // array of option IDs in shuffled order

  session  AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id])

  @@unique([sessionId, position])
}

// ============================================================
// STUDENT ANSWERS
// ============================================================

model StudentAnswer {
  id              String    @id @default(cuid())
  sessionId       String
  questionId      String
  // for choice questions: array of selected option IDs
  selectedOptions Json?
  // for fill blank / essay / ordering
  textAnswer      String?
  orderAnswer     Json? // array of item IDs in student's order
  matchAnswer     Json? // { leftId: rightId } map
  // scoring (null until graded)
  marksAwarded    Decimal?  @db.Decimal(6, 2)
  isCorrect       Boolean?
  isManualGraded  Boolean   @default(false)
  gradedAt        DateTime?
  gradedById      String? // staff who manually graded

  answeredAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session  AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id])
  gradedBy Staff?            @relation("AnswerGrader", fields: [gradedById], references: [id])

  @@unique([sessionId, questionId])
}

// ============================================================
// VIOLATIONS
// ============================================================

enum ViolationType {
  FULLSCREEN_EXIT
  TAB_SWITCH
  COPY_ATTEMPT
  PASTE_ATTEMPT
  DEVTOOLS_OPEN
  FACE_NOT_DETECTED
  FACE_MISMATCH
  MULTIPLE_FACES
  IDLE_TIMEOUT
  NETWORK_DROP
  SCREEN_CAPTURE
  FOCUS_LOSS
  KEYBOARD_SHORTCUT
  CLOCK_TAMPER
}

model Violation {
  id         String        @id @default(cuid())
  sessionId  String
  type       ViolationType
  severity   Int           @default(1) // 1=warn, 2=serious, 3=critical
  metadata   Json? // e.g. { faceScore: 0.4 }
  screenshot String? // file path
  createdAt  DateTime      @default(now())

  // cooldown: prevent duplicate logging within N seconds
  // (enforced in application layer)

  session AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, type])
  @@index([sessionId, createdAt])
}

// ============================================================
// RESULTS & GRADING
// ============================================================

model AssessmentResult {
  id           String @id @default(cuid())
  sessionId    String @unique
  assessmentId String
  studentId    String

  // raw scores
  totalMarks    Decimal @db.Decimal(6, 2) // max possible
  marksObtained Decimal @db.Decimal(6, 2)
  percentage    Decimal @db.Decimal(5, 2)

  // computed grade (stored permanently — never recalculate)
  grade       GradeLabel
  gradePoints Decimal    @db.Decimal(3, 1) // 5.0, 4.0, ...
  passed      Boolean

  // per-section breakdown (optional JSON for future use)
  breakdown Json?

  // for combined CA + Exam: contributions stored separately
  // (CA result from Test, Exam result from Examination, combined in TranscriptEntry)

  isReleased   Boolean   @default(false)
  releasedAt   DateTime?
  releasedById String?

  // immutability: once released, any change creates a revision
  isRevised     Boolean @default(false)
  revisedFromId String? // original result ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session    AssessmentSession @relation(fields: [sessionId], references: [id])
  assessment Assessment        @relation(fields: [assessmentId], references: [id])
  student    Student           @relation(fields: [studentId], references: [id])
  releasedBy Staff?            @relation("ResultReleaser", fields: [releasedById], references: [id])
  revisions  ResultRevision[]

  @@index([assessmentId, studentId])
  @@index([isReleased])
}

// Every modification to a released result is tracked here
// Original result row is never changed
model ResultRevision {
  id          String   @id @default(cuid())
  resultId    String
  revisedById String
  reason      String
  beforeData  Json // snapshot of result before change
  afterData   Json // snapshot after change
  createdAt   DateTime @default(now())

  result    AssessmentResult @relation(fields: [resultId], references: [id])
  revisedBy Staff            @relation(fields: [revisedById], references: [id])
}

// ============================================================
// GRADE SCALE (configurable per institution)
// ============================================================

model GradeScale {
  id          String     @id @default(cuid())
  label       GradeLabel @unique
  minPercent  Decimal    @db.Decimal(5, 2)
  maxPercent  Decimal    @db.Decimal(5, 2)
  points      Decimal    @db.Decimal(3, 1)
  description String?

  @@index([minPercent])
}

// ============================================================
// COMBINED SCORE (CA 30 + Exam 70 = Final 100)
// ============================================================

model TranscriptEntry {
  id        String @id @default(cuid())
  studentId String
  courseId  String
  sessionId String // academic session

  testMark    Decimal?    @db.Decimal(5, 2) // out of 30
  examMark    Decimal?    @db.Decimal(5, 2) // out of 70
  totalMark   Decimal?    @db.Decimal(5, 2) // out of 100
  percentage  Decimal?    @db.Decimal(5, 2)
  grade       GradeLabel?
  gradePoints Decimal?    @db.Decimal(3, 1)
  passed      Boolean?
  creditUnits Int?

  isFinalized Boolean   @default(false)
  finalizedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student         @relation(fields: [studentId], references: [id])
  course  Course          @relation(fields: [courseId], references: [id])
  session AcademicSession @relation(fields: [sessionId], references: [id])

  @@unique([studentId, courseId, sessionId])
  @@index([studentId, sessionId])
}


