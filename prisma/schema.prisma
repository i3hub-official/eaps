// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum StaffRole {
  SUPER_ADMIN
  VC
  DVC
  REGISTRAR
  UNIVERSITY_EXAM_OFFICER
  UNIVERSITY_COURSE_COORDINATOR
  DEAN
  HOD
  COLLEGE_EXAM_OFFICER
  COLLEGE_COORDINATOR
  DEPARTMENT_EXAM_OFFICER
  DEPARTMENT_COORDINATOR
  LECTURER
  INVIGILATOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  EXPELLED
  GRADUATED
  WITHDRAWN
  DEFERRED
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  RETIRED
}

enum SemesterType {
  FIRST
  SECOND
  SUMMER
}

enum ProgrammeType {
  UNDERGRADUATE
  POSTGRADUATE_DIPLOMA
  CEC
  MASTERS
  PHD
  CERTIFICATE
  DIPLOMA
}

enum AcademicSessionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum CourseStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum CourseType {
  COMPULSORY
  ELECTIVE
  GENERAL_STUDIES
  CARRYOVER_ELIGIBLE
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RegistrationType {
  NORMAL
  CARRY_OVER
  EXTRA
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
}

enum AssessmentType {
  PRACTICE
  ASSIGNMENT
  TEST
  EXAMINATION
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  MATCHING
  ESSAY
  ORDERING
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  SUBMITTED
  TIMED_OUT
  DISQUALIFIED
}

enum SubmissionMode {
  MANUAL
  AUTO_TIME
  AUTO_VIOLATION
  FORCE
}

enum GradeLabel {
  A
  B
  C
  D
  E
  F
}

enum ViolationType {
  FULLSCREEN_EXIT
  TAB_SWITCH
  COPY_ATTEMPT
  PASTE_ATTEMPT
  DEVTOOLS_OPEN
  FACE_NOT_DETECTED
  FACE_MISMATCH
  MULTIPLE_FACES
  IDLE_TIMEOUT
  NETWORK_DROP
  SCREEN_CAPTURE
  FOCUS_LOSS
  KEYBOARD_SHORTCUT
  CLOCK_TAMPER
}

enum NotificationType {
  REGISTRATION_REMINDER
  MISSING_COURSE_ALERT
  EXAM_SCHEDULE
  FACE_ENROLLMENT_REMINDER
  PAYMENT_REMINDER
  RESULT_RELEASED
  EXAM_STARTING
  VIOLATION_ALERT
  PENDING_APPROVAL
  GENERAL
}

enum ConversationStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ============================================================
// RBAC
// ============================================================

model OtpRecord {
  id        String   @id @default(cuid())
  email     String
  otp       String
  type      String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Lookup: find valid OTP for a given email+type, filter out used/expired
  @@index([email, type, used, expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userType   String
  staffId    String?
  studentId  String?
  tokenHash  String    @unique // primary lookup — always by tokenHash
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  staff   Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Cleanup queries: find all tokens for a user to invalidate old ones
  @@index([staffId])
  @@index([studentId])
}

model VerificationToken {
  id         String    @id @default(cuid())
  userType   String
  staffId    String?
  studentId  String?
  tokenHash  String    @unique // primary lookup
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  staff   Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([studentId])
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // always looked up by name
  description String?
  group       String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  // Group listing for admin UI
  @@index([group])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // always looked up by name
  displayName String
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  staffRoles  StaffRoleAssignment[]
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  // permissionId alone for reverse lookup (which roles have this permission?)
  @@index([permissionId])
}

model StaffRoleAssignment {
  id         String    @id @default(cuid())
  staffId    String
  roleId     String
  assignedBy String?
  assignedAt DateTime  @default(now())
  expiresAt  DateTime?
  isActive   Boolean   @default(true)

  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner Staff? @relation("RoleAssigner", fields: [assignedBy], references: [id])

  @@unique([staffId, roleId])
  // Auth guard: fetch all active roles for a staff member
  @@index([staffId, isActive])
}

// ============================================================
// ACADEMIC STRUCTURE
// ============================================================

model University {
  id        String   @id @default(cuid())
  name      String
  shortName String   @unique
  address   String?
  website   String?
  email     String?
  phone     String?
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  colleges College[]
}

model College {
  id           String   @id @default(cuid())
  universityId String
  name         String
  shortName    String
  code         String   @unique
  email        String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university       University        @relation(fields: [universityId], references: [id])
  departments      Department[]
  staff            Staff[]
  staffInvitations StaffInvitation[]

  @@unique([universityId, shortName])
  // List all colleges for a university (course dialog dropdown)
  @@index([universityId])
}

model Department {
  id        String   @id @default(cuid())
  collegeId String
  name      String
  shortName String
  code      String   @unique
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college          College                 @relation(fields: [collegeId], references: [id])
  programmes       Programme[]
  staff            Staff[]
  students         Student[]
  courses          Course[]
  eligibility      AssessmentEligibility[]
  conversations    Conversation[]
  staffInvitations StaffInvitation[]

  @@unique([collegeId, shortName])
  // List departments per college (cascade filter in course dialog)
  @@index([collegeId])
}

model Programme {
  id            String        @id @default(cuid())
  departmentId  String
  name          String
  shortName     String
  type          ProgrammeType @default(UNDERGRADUATE)
  durationYears Int           @default(4)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  students   Student[]

  @@unique([departmentId, shortName])
  @@index([departmentId, isActive])
}

model Level {
  id        String   @id @default(cuid())
  name      Int      @unique // 100, 200, 300 — always looked up by name
  label     String
  createdAt DateTime @default(now())

  courseRegistrations CourseRegistration[]
  courses             Course[]
  students            Student[]               @relation("CurrentLevel")
  eligibility         AssessmentEligibility[]
}

model AcademicSession {
  id        String                @id @default(cuid())
  name      String                @unique
  startDate DateTime
  endDate   DateTime
  status    AcademicSessionStatus @default(UPCOMING)
  isCurrent Boolean               @default(false)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  semesters           Semester[]
  courseRegistrations CourseRegistration[]
  transcriptEntries   TranscriptEntry[]

  // Hot path: findFirst({ where: { isCurrent: true } }) — called on every page load
  @@index([isCurrent])
  @@index([status])
}

model Semester {
  id                  String       @id @default(cuid())
  sessionId           String
  type                SemesterType
  startDate           DateTime
  endDate             DateTime
  registrationEnabled Boolean      @default(true)
  regOpenAt           DateTime?
  regCloseAt          DateTime?
  isCurrent           Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  session             AcademicSession      @relation(fields: [sessionId], references: [id])
  courseRegistrations CourseRegistration[]
  courses             CourseOffering[]

  @@unique([sessionId, type])
  // Hot path: findFirst({ where: { sessionId, isCurrent: true } }) — every page load
  @@index([sessionId, isCurrent])
}

// ============================================================
// COURSES
// ============================================================

model Course {
  id           String       @id @default(cuid())
  departmentId String
  levelId      String
  code         String       @unique
  title        String
  creditUnits  Int          @default(2)
  type         CourseType   @default(COMPULSORY)
  status       CourseStatus @default(ACTIVE)
  description  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  department        Department              @relation(fields: [departmentId], references: [id])
  level             Level                   @relation(fields: [levelId], references: [id])
  offerings         CourseOffering[]
  registrations     CourseRegistration[]
  questions         Question[]
  assessments       Assessment[]
  transcriptEntries TranscriptEntry[]
  invitations       StaffInvitationCourse[]

  // Hot path: fetch all active courses for a level (course registration load)
  @@index([levelId, status])
  // Filter by department within a level (recommended courses)
  @@index([departmentId, levelId, status])
}

model CourseOffering {
  id         String   @id @default(cuid())
  courseId   String
  semesterId String
  lecturerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course   Course   @relation(fields: [courseId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])
  lecturer Staff?   @relation("CourseOfferings", fields: [lecturerId], references: [id])

  attendanceSessions AttendanceSession[]

  @@unique([courseId, semesterId])
  // Fetch all offerings for a semester (used in course query via relation filter)
  @@index([semesterId])
  // Lecturer's offerings list
  @@index([lecturerId, semesterId])
}

// ============================================================
// COURSE REGISTRATION
// ============================================================

model CourseRegistration {
  id           String             @id @default(cuid())
  studentId    String
  courseId     String
  sessionId    String
  semesterId   String
  levelId      String
  type         RegistrationType   @default(NORMAL)
  status       RegistrationStatus @default(PENDING)
  editCount    Int                @default(0)
  approvedBy   String?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectedNote String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  student  Student         @relation(fields: [studentId], references: [id])
  course   Course          @relation(fields: [courseId], references: [id])
  session  AcademicSession @relation(fields: [sessionId], references: [id])
  semester Semester        @relation(fields: [semesterId], references: [id])
  level    Level           @relation(fields: [levelId], references: [id])
  approver Staff?          @relation("RegistrationApprover", fields: [approvedBy], references: [id])

  @@unique([studentId, courseId, sessionId, semesterId])
  // Hot path: student's registrations for a semester (page load + drop action)
  @@index([studentId, sessionId, semesterId, status])
  // Admin: all registrations for a semester (approval queue)
  @@index([semesterId, status, createdAt])
  // Admin: all registrations for a course
  @@index([courseId, semesterId, status])
  // Approver lookup
  @@index([approvedBy])
}

// ============================================================
// ATTENDANCE
// ============================================================

model AttendanceSession {
  id               String   @id @default(cuid())
  courseOfferingId String
  title            String?
  date             DateTime
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  courseOffering CourseOffering     @relation(fields: [courseOfferingId], references: [id])
  createdBy      Staff              @relation("AttendanceCreator", fields: [createdById], references: [id])
  records        AttendanceRecord[]

  @@index([courseOfferingId, date])
  // Lecturer's own sessions
  @@index([createdById, date])
}

model AttendanceRecord {
  id                  String           @id @default(cuid())
  attendanceSessionId String
  studentId           String
  status              AttendanceStatus @default(ABSENT)
  markedById          String?
  note                String?
  markedAt            DateTime         @default(now())

  attendanceSession AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  student           Student           @relation(fields: [studentId], references: [id])
  markedBy          Staff?            @relation("AttendanceMarker", fields: [markedById], references: [id])

  @@unique([attendanceSessionId, studentId])
  // Student's attendance history across all courses
  @@index([studentId, status])
}

// ============================================================
// STAFF
// ============================================================

model Staff {
  id                 String      @id @default(cuid())
  staffNumber        String      @unique
  email              String
  emailHash          String      @unique
  passwordHash       String
  firstNameHash      String
  firstName          String
  lastNameHash       String
  lastName           String
  otherNamesHash     String?
  otherNames         String?
  phone              String?
  phoneHash          String?
  gender             Gender?
  avatar             String?
  primaryRole        StaffRole
  collegeId          String?
  departmentId       String?
  status             StaffStatus @default(ACTIVE)
  mustChangePassword Boolean     @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  college    College?    @relation(fields: [collegeId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  roleAssignments StaffRoleAssignment[]
  assignedRoles   StaffRoleAssignment[] @relation("RoleAssigner")

  authoredQuestions Question[]           @relation("QuestionAuthor")
  sessions          StaffSession[]
  courseOfferings   CourseOffering[]     @relation("CourseOfferings")
  approvedRegs      CourseRegistration[] @relation("RegistrationApprover")
  auditLogs         AuditLog[]
  passwordResets    PasswordResetToken[]

  createdAssessments Assessment[]            @relation("AssessmentAuthor")
  invigilations      AssessmentInvigilator[]
  gradedAnswers      StudentAnswer[]         @relation("AnswerGrader")
  releasedResults    AssessmentResult[]      @relation("ResultReleaser")
  resultRevisions    ResultRevision[]

  emailVerifiedAt    DateTime?
  verificationTokens VerificationToken[]

  createdAttendanceSessions AttendanceSession[] @relation("AttendanceCreator")
  markedAttendanceRecords   AttendanceRecord[]  @relation("AttendanceMarker")
  assignedConversations     Conversation[]      @relation("AssignedConversations")
  sentMessages              Message[]           @relation("SentMessages")
  sentInvitations           StaffInvitation[]   @relation("InvitationSender")
  acceptedInvitation        StaffInvitation?    @relation("InvitationAcceptedStaff")
  preferences               StaffPreference?

  // Auth: identifier-first login
  @@index([emailHash])
  @@index([staffNumber])
  // Name search
  @@index([firstNameHash])
  @@index([lastNameHash])
  // Admin staff list filtered by college/dept/role/status
  @@index([collegeId, departmentId, primaryRole, status])
  // Last active / activity dashboards
  @@index([status, lastLoginAt])
}

model StaffSession {
  id                    String    @id @default(cuid())
  staffId               String
  token                 String    @unique // primary auth lookup
  refreshToken          String?   @unique
  ipAddress             String?
  userAgent             String?
  expiresAt             DateTime
  createdAt             DateTime  @default(now())
  refreshTokenExpiresAt DateTime?
  lastActiveAt          DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  // Invalidate all sessions for a staff member (logout everywhere / suspension)
  @@index([staffId, expiresAt])
}

model StaffInvitation {
  id              String           @id @default(cuid())
  email           String
  primaryRole     StaffRole
  collegeId       String
  departmentId    String
  // Levels this invitee is eligible to teach, e.g. [100, 200] — mirrors the
  // lecturer-pool eligibility concept from the seed script (levels +
  // maxCourseLoad), kept here as reference/filter metadata rather than a
  // permanent Staff field, since specific course assignment is what
  // actually matters once onboarding completes.
  levels          Int[]
  tokenHash       String           @unique
  status          InvitationStatus @default(PENDING)
  invitedById     String
  expiresAt       DateTime
  acceptedAt      DateTime?
  acceptedStaffId String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  college       College                 @relation(fields: [collegeId], references: [id])
  department    Department              @relation(fields: [departmentId], references: [id])
  invitedBy     Staff                   @relation("InvitationSender", fields: [invitedById], references: [id])
  acceptedStaff Staff?                  @relation("InvitationAcceptedStaff", fields: [acceptedStaffId], references: [id])
  courses       StaffInvitationCourse[]

  @@index([email])
  @@index([status])
}

model StaffInvitationCourse {
  invitationId String
  courseId     String

  invitation StaffInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  course     Course          @relation(fields: [courseId], references: [id])

  @@id([invitationId, courseId])
}

// ============================================================
// STUDENT
// ============================================================

model Student {
  id                  String        @id @default(cuid())
  matricNumber        String        @unique
  jambRegNo           String        @unique
  receiptNo           String?
  receiptNoHash       String?       @unique
  receiptRef          String?
  receiptRefHash      String?       @unique
  receiptSource       String?
  registrationSession String?
  email               String        @unique
  emailHash           String        @unique
  passwordHash        String
  firstName           String
  lastName            String
  otherNames          String?
  phone               String?
  phoneHash           String?       @unique
  gender              Gender?
  avatar              String?
  dateOfBirth         DateTime?
  departmentId        String
  programmeId         String
  currentLevelId      String
  entryYear           Int
  status              StudentStatus @default(ACTIVE)
  faceEnrolledAt      DateTime?
  mustChangePassword  Boolean       @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  department   Department @relation(fields: [departmentId], references: [id])
  programme    Programme  @relation(fields: [programmeId], references: [id])
  currentLevel Level      @relation("CurrentLevel", fields: [currentLevelId], references: [id])

  sessions            StudentSession[]
  courseRegistrations CourseRegistration[]
  faceDescriptor      FaceDescriptor?
  notifications       Notification[]
  auditLogs           AuditLog[]
  eligibility         AssessmentEligibility[]
  assessmentSessions  AssessmentSession[]
  results             AssessmentResult[]
  transcriptEntries   TranscriptEntry[]
  passwordResets      PasswordResetToken[]
  emailVerifiedAt     DateTime?
  verificationTokens  VerificationToken[]
  attendanceRecords   AttendanceRecord[]
  tagPerformance      TagPerformance[]
  conversations       Conversation[]
  sentMessages        Message[]               @relation("SentMessages")
  preference          StudentPreference?

  // Auth: identifier-first login
  @@index([emailHash])
  @@index([matricNumber])
  @@index([jambRegNo])
  // Admin student list filtered by dept/level/status
  @@index([departmentId, currentLevelId, status])
  // Cohort queries (entry year reports)
  @@index([entryYear, departmentId, status])
  // Face enrollment reminder jobs
  @@index([faceEnrolledAt, status])
  // Last active / activity dashboards
  @@index([status, lastLoginAt])
}

model StudentSession {
  id                    String    @id @default(cuid())
  studentId             String
  token                 String    @unique // primary auth lookup
  refreshToken          String?   @unique
  ipAddress             String?
  userAgent             String?
  deviceFingerprint     String?
  expiresAt             DateTime
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  lastActiveAt          DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Invalidate all sessions for a student (logout everywhere / suspension)
  @@index([studentId, expiresAt])
}

model TagPerformance {
  id             String    @id @default(cuid())
  studentId      String
  tagId          String
  courseId       String?
  attempts       Int       @default(0)
  correct        Int       @default(0)
  marksTotal     Decimal   @default(0) @db.Decimal(8, 2)
  marksEarned    Decimal   @default(0) @db.Decimal(8, 2)
  lastAnsweredAt DateTime?
  updatedAt      DateTime  @updatedAt

  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tag     QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([studentId, tagId, courseId])
  @@index([tagId, courseId])
}

// ============================================================
// FACE RECOGNITION
// ============================================================

model FaceDescriptor {
  id                String    @id @default(cuid())
  studentId         String    @unique
  encryptedData     String
  iv                String
  enrolledAt        DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  enrolledIpAddress String?
  student           Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  studentId String?
  staffId   String?
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  link      String?
  createdAt DateTime         @default(now())

  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Student inbox: unread first, then by date
  @@index([studentId, isRead, createdAt])
  // Staff inbox
  @@index([staffId, isRead, createdAt])
  // Job: send scheduled notification type to all unread recipients
  @@index([type, isRead])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  actorType  String
  staffId    String?
  studentId  String?
  action     String
  entity     String
  entityId   String?
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  staff   Staff?   @relation(fields: [staffId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@index([actorType, staffId])
  @@index([actorType, studentId])
  @@index([entity, entityId])
  // Time-range queries for audit reports
  @@index([createdAt])
  // Filter by action within an entity (e.g. all RESULT_RELEASED on Assessment)
  @@index([entity, action, createdAt])
}

// ============================================================
// QUESTION BANK
// ============================================================

model QuestionTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  questions          QuestionTagMap[]
  studentPerformance TagPerformance[]
  assessmentTags     AssessmentTag[]
}

model QuestionTagMap {
  questionId String
  tagId      String

  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  // Reverse: all questions for a tag (bank search by tag)
  @@index([tagId])
}

model Question {
  id          String          @id @default(cuid())
  createdById String
  courseId    String?
  type        QuestionType
  difficulty  DifficultyLevel @default(MEDIUM)
  body        String
  explanation String?
  imageUrl    String?
  audioUrl    String?
  videoUrl    String?
  marks       Decimal         @default(1) @db.Decimal(6, 2)
  isActive    Boolean         @default(true)
  version     Int             @default(1)
  parentId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy Staff      @relation("QuestionAuthor", fields: [createdById], references: [id])
  course    Course?    @relation(fields: [courseId], references: [id])
  parent    Question?  @relation("QuestionVersions", fields: [parentId], references: [id])
  versions  Question[] @relation("QuestionVersions")

  options       QuestionOption[]
  matchPairs    MatchPair[]
  tags          QuestionTagMap[]
  assessmentQs  AssessmentQuestion[]
  answers       StudentAnswer[]
  sessionOrders SessionQuestionOrder[]

  // Bank search: active questions for a course filtered by type/difficulty
  @@index([courseId, isActive, type, difficulty])
  // Lecturer's own questions
  @@index([createdById, isActive])
  // Version chain lookup
  @@index([parentId])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  body       String
  imageUrl   String?
  isCorrect  Boolean @default(false)
  order      Int     @default(0)
  isActive   Boolean @default(true)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Load all options for a question ordered
  @@index([questionId, order])
}

model MatchPair {
  id         String @id @default(cuid())
  questionId String
  leftItem   String
  rightItem  String
  order      Int    @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
}

// ============================================================
// ASSESSMENTS
// ============================================================

model Assessment {
  id                    String           @id @default(cuid())
  createdById           String
  courseId              String
  type                  AssessmentType
  status                AssessmentStatus @default(DRAFT)
  title                 String
  instructions          String?
  totalMarks            Decimal          @db.Decimal(6, 2)
  passMark              Decimal          @db.Decimal(6, 2)
  durationMinutes       Int
  startTime             DateTime?
  endTime               DateTime?
  maxAttempts           Int              @default(1)
  questionCount         Int
  shuffleQuestions      Boolean          @default(true)
  shuffleOptions        Boolean          @default(true)
  showResultImmediately Boolean          @default(false)
  allowReview           Boolean          @default(false)
  requireFaceVerify     Boolean          @default(false)
  requireLiveness       Boolean          @default(false)
  offlineEnabled        Boolean          @default(false)
  fullscreenRequired    Boolean          @default(false)
  dueDate               DateTime?
  allowLateSubmission   Boolean          @default(false)
  latePenaltyPercent    Decimal?         @db.Decimal(5, 2)
  paperVariants         Int              @default(1)
  // ─── Attempt Management ───────────────────────────────────────────────
  /// Allow students to retake the assessment
  allowRetakes        Boolean           @default(false)
  
  /// Minutes to wait between attempts (0 = immediate retake allowed)
  retakeDelayMinutes  Int               @default(0)
  
  /// Show previous attempt details and scores to students
  showPreviousAttempts Boolean          @default(false)
  
  /// Report best score across attempts (else report latest)
  bestScoreOnly       Boolean           @default(true)
  
  /// Allow viewing answers from previous attempts
  reviewPreviousAttempts Boolean        @default(false)
  publishedAt           DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  tags         AssessmentTag[]
  createdBy    Staff                   @relation("AssessmentAuthor", fields: [createdById], references: [id])
  course       Course                  @relation(fields: [courseId], references: [id])
  questions    AssessmentQuestion[]
  sessions     AssessmentSession[]
  invigilators AssessmentInvigilator[]
  eligibility  AssessmentEligibility[]
  results      AssessmentResult[]

  // Student dashboard: active/scheduled assessments for a course
  @@index([courseId, status])
  // Lecturer's assessments
  @@index([createdById, status])
  // Scheduler job: find assessments whose window just opened/closed
  @@index([status, startTime, endTime])
}

model AssessmentTag {
  assessmentId String
  tagId        String

  assessment Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  tag        QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assessmentId, tagId])
  @@index([tagId])
}

model AssessmentQuestion {
  id            String   @id @default(cuid())
  assessmentId  String
  questionId    String
  order         Int      @default(0)
  marksOverride Decimal? @db.Decimal(6, 2)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
  // Load question pool for an assessment in order
  @@index([assessmentId, order])
}

model AssessmentEligibility {
  id           String  @id @default(cuid())
  assessmentId String
  departmentId String?
  levelId      String?
  studentId    String?

  assessment Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  level      Level?      @relation(fields: [levelId], references: [id])
  student    Student?    @relation(fields: [studentId], references: [id])

  @@unique([assessmentId, departmentId, levelId, studentId])
  // Check if a student is eligible: match by dept+level or individual override
  @@index([assessmentId, departmentId, levelId])
  @@index([assessmentId, studentId])
}

model AssessmentInvigilator {
  id           String   @id @default(cuid())
  assessmentId String
  staffId      String
  assignedAt   DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  staff      Staff      @relation(fields: [staffId], references: [id])

  @@unique([assessmentId, staffId])
  // Staff: which exams am I invigilating?
  @@index([staffId])
}

// ============================================================
// ASSESSMENT SESSIONS
// ============================================================

model AssessmentSession {
  id            String        @id @default(cuid())
  assessmentId  String
  studentId     String
  attemptNumber Int           @default(1)
  status        SessionStatus @default(PENDING)
  paperVariant  String?

  startedAt       DateTime?
  submittedAt     DateTime?
  expiresAt       DateTime?
  termsAcceptedAt DateTime?

  submissionMode    SubmissionMode?
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?

  faceVerifiedAt DateTime?
  faceScore      Float?

  timeRemainingSeconds Int?

  isOffline  Boolean   @default(false)
  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessment    Assessment             @relation(fields: [assessmentId], references: [id])
  student       Student                @relation(fields: [studentId], references: [id])
  answers       StudentAnswer[]
  violations    Violation[]
  result        AssessmentResult?
  questionOrder SessionQuestionOrder[]

  @@unique([assessmentId, studentId, attemptNumber])
  // Invigilator/admin: all sessions for an assessment by status
  @@index([assessmentId, status])
  // Student: my sessions
  @@index([studentId, status])
  // Resume: find an in-progress session for a student
  @@index([studentId, assessmentId, status])
  // Auto-submit job: sessions that have expired but not yet submitted
  @@index([status, expiresAt])
}

model SessionQuestionOrder {
  id          String @id @default(cuid())
  sessionId   String
  questionId  String
  position    Int
  optionOrder Json

  session  AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id])

  @@unique([sessionId, position])
  // Jump to a specific question in a session
  @@index([sessionId, questionId])
}

// ============================================================
// STUDENT ANSWERS
// ============================================================

model StudentAnswer {
  id              String    @id @default(cuid())
  sessionId       String
  questionId      String
  selectedOptions Json?
  textAnswer      String?
  orderAnswer     Json?
  matchAnswer     Json?
  marksAwarded    Decimal?  @db.Decimal(6, 2)
  isCorrect       Boolean?
  isManualGraded  Boolean   @default(false)
  gradedAt        DateTime?
  gradedById      String?

  answeredAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session  AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id])
  gradedBy Staff?            @relation("AnswerGrader", fields: [gradedById], references: [id])

  @@unique([sessionId, questionId])
  // Grading queue: ungraded essay/manual answers for a session
  @@index([sessionId, isManualGraded, isCorrect])
  // Grader's workload
  @@index([gradedById, gradedAt])
}

// ============================================================
// VIOLATIONS
// ============================================================

model Violation {
  id         String        @id @default(cuid())
  sessionId  String
  type       ViolationType
  severity   Int           @default(1)
  metadata   Json?
  screenshot String?
  createdAt  DateTime      @default(now())

  session AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, type])
  @@index([sessionId, createdAt])
  // Auto-disqualify job: sessions with critical violations
  @@index([sessionId, severity, createdAt])
}

// ============================================================
// RESULTS & GRADING
// ============================================================

model AssessmentResult {
  id           String @id @default(cuid())
  sessionId    String @unique
  assessmentId String
  studentId    String

  totalMarks    Decimal @db.Decimal(6, 2)
  marksObtained Decimal @db.Decimal(6, 2)
  percentage    Decimal @db.Decimal(5, 2)

  grade       GradeLabel
  gradePoints Decimal    @db.Decimal(3, 1)
  passed      Boolean

  breakdown Json?

  isReleased   Boolean   @default(false)
  releasedAt   DateTime?
  releasedById String?

  isRevised     Boolean @default(false)
  revisedFromId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session    AssessmentSession @relation(fields: [sessionId], references: [id])
  assessment Assessment        @relation(fields: [assessmentId], references: [id])
  student    Student           @relation(fields: [studentId], references: [id])
  releasedBy Staff?            @relation("ResultReleaser", fields: [releasedById], references: [id])
  revisions  ResultRevision[]

  // Student: my results across assessments
  @@index([studentId, isReleased])
  // Admin: release queue for an assessment
  @@index([assessmentId, isReleased])
  // Result release job
  @@index([isReleased, releasedAt])
}

model ResultRevision {
  id          String   @id @default(cuid())
  resultId    String
  revisedById String
  reason      String
  beforeData  Json
  afterData   Json
  createdAt   DateTime @default(now())

  result    AssessmentResult @relation(fields: [resultId], references: [id])
  revisedBy Staff            @relation(fields: [revisedById], references: [id])

  @@index([resultId])
  @@index([revisedById])
}

// ============================================================
// GRADE SCALE
// ============================================================

model GradeScale {
  id          String     @id @default(cuid())
  label       GradeLabel @unique
  minPercent  Decimal    @db.Decimal(5, 2)
  maxPercent  Decimal    @db.Decimal(5, 2)
  points      Decimal    @db.Decimal(3, 1)
  description String?

  @@index([minPercent])
}

// ============================================================
// TRANSCRIPT
// ============================================================

model TranscriptEntry {
  id        String @id @default(cuid())
  studentId String
  courseId  String
  sessionId String

  testMark    Decimal?    @db.Decimal(5, 2)
  examMark    Decimal?    @db.Decimal(5, 2)
  totalMark   Decimal?    @db.Decimal(5, 2)
  percentage  Decimal?    @db.Decimal(5, 2)
  grade       GradeLabel?
  gradePoints Decimal?    @db.Decimal(3, 1)
  passed      Boolean?
  creditUnits Int?

  isFinalized Boolean   @default(false)
  finalizedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student         @relation(fields: [studentId], references: [id])
  course  Course          @relation(fields: [courseId], references: [id])
  session AcademicSession @relation(fields: [sessionId], references: [id])

  @@unique([studentId, courseId, sessionId])
  // Student transcript page
  @@index([studentId, sessionId])
  // Finalization job
  @@index([studentId, isFinalized])
  // Course performance analytics
  @@index([courseId, sessionId, passed])
}

// ============================================================
// MESSAGING
// ============================================================

model Conversation {
  id            String             @id @default(cuid())
  studentId     String
  departmentId  String?
  assignedToId  String?
  subject       String
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  assignedTo Staff?      @relation("AssignedConversations", fields: [assignedToId], references: [id])
  messages   Message[]

  @@index([studentId, status])
  @@index([departmentId, status])
  @@index([assignedToId, status])
  // Sort inbox by most recent message
  @@index([status, lastMessageAt])
}

model Message {
  id              String    @id @default(cuid())
  conversationId  String
  senderType      String
  senderStaffId   String?
  senderStudentId String?
  body            String
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderStaff   Staff?       @relation("SentMessages", fields: [senderStaffId], references: [id])
  senderStudent Student?     @relation("SentMessages", fields: [senderStudentId], references: [id])

  @@index([conversationId, createdAt])
  // Unread count per conversation
  @@index([conversationId, readAt])
}

model StudentPreference {
  id        String @id @default(cuid())
  studentId String @unique

  // Example shape stored in `data`:
  // {
  //   "resultsViewMode": "card",       // ViewMode for Assessment Results tab
  //   "transcriptViewMode": "list"     // ViewMode for By Assessment Type section
  // }
  data Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_preferences")
}

model StaffPreference {
  id      String @id @default(cuid())
  staffId String @unique

  data Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_preferences")
}
